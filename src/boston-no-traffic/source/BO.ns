script BO_BeatBoxScript {
    while {
        Wait 0.03 second 
        Obj_ApplyScaling {y=0.95 z=0.95} 
        Wait 0.3 second 
        Obj_ApplyScaling {y=1.0 z=1.0} 
        Wait 0.01 second 
        Obj_ApplyScaling {y=0.98 z=0.98} 
        Wait 0.01 second 
        Obj_ApplyScaling {y=1.0 z=1.0} 
        Wait 0.01 second 
    } 
} 
