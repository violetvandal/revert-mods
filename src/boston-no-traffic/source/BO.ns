        Kill name=TRG_Car_Street_C02 
        Kill name=TRG_Car_Street_CC01 
        Kill name=TRG_Car_Street_CC02 
        Kill name=TRG_Car_Street_CC03 
        Kill name=TRG_Car_Street_CC04 
    } 
} 
