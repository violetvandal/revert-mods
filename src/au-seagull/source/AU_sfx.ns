script AU_SFX_Snoring_Worker {
    if ! IsStreamPlaying CraneEngineIdleSFX {
        Obj_PlayStream SK6_AU_CraneEngineIdle vol=150 emitter=TRG_SFX_SOB_SnoringWorker id=CraneEngineIdleSFX num_loops=-1 priority=StreamPriorityMidHigh dropoff_function=exponential 
    } 
    if ! InNetGame {
        while {
            if ! IsStreamPlaying ConstructionSnoring {
                random2 {
1 { Obj_PlayStream AU_WorkerSnoring01 vol=200 emitter=TRG_SFX_SOB_SnoringWorker priority=StreamPriorityLowMid id=ConstructionSnoring 
 } 1 { Obj_PlayStream AU_WorkerSnoring02 vol=200 emitter=TRG_SFX_SOB_SnoringWorker priority=StreamPriorityLowMid id=ConstructionSnoring 
 } 1 { Obj_PlayStream AU_WorkerSnoring03 vol=200 emitter=TRG_SFX_SOB_SnoringWorker priority=StreamPriorityLowMid id=ConstructionSnoring 
 } 1 { Obj_PlayStream AU_WorkerSnoring04 vol=200 emitter=TRG_SFX_SOB_SnoringWorker priority=StreamPriorityLowMid id=ConstructionSnoring 
 } 1 { Obj_PlayStream AU_WorkerSnoring05 vol=200 emitter=TRG_SFX_SOB_SnoringWorker priority=StreamPriorityLowMid id=ConstructionSnoring 
 } } 
            } 
            wait 2 seconds 
        } 
    } 
} 
