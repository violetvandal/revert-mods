script SFX_HandleLandOnSand {
    random2 {
1 { Obj_PlaySound (SFX_FootStepRun01) pitch=randomrange(97.0, 102.0) vol=randomrange(105.0, 120.0) 
 } 1 { Obj_PlaySound (SFX_FootStepRun02) pitch=randomrange(97.0, 102.0) vol=randomrange(105.0, 120.0) 
 } 1 { Obj_PlaySound (SFX_FootStepRun03) pitch=randomrange(97.0, 102.0) vol=randomrange(105.0, 120.0) 
 } 1 { Obj_PlaySound (SFX_FootStepRun04) pitch=randomrange(97.0, 102.0) vol=randomrange(105.0, 120.0) 
 } 1 { Obj_PlaySound (SFX_FootStepRun05) pitch=randomrange(97.0, 102.0) vol=randomrange(105.0, 120.0) 
 } } 
    wait 0.1 seconds 
    random2 {
1 { Obj_PlaySound (SFX_FootStepRun01) pitch=randomrange(97.0, 102.0) vol=randomrange(105.0, 120.0) 
 } 1 { Obj_PlaySound (SFX_FootStepRun02) pitch=randomrange(97.0, 102.0) vol=randomrange(105.0, 120.0) 
 } 1 { Obj_PlaySound (SFX_FootStepRun03) pitch=randomrange(97.0, 102.0) vol=randomrange(105.0, 120.0) 
 } 1 { Obj_PlaySound (SFX_FootStepRun04) pitch=randomrange(97.0, 102.0) vol=randomrange(105.0, 120.0) 
 } 1 { Obj_PlaySound (SFX_FootStepRun05) pitch=randomrange(97.0, 102.0) vol=randomrange(105.0, 120.0) 
 } } 
} 
script AU_SFX_Pigeons_Idle {
    if skatercamanimfinished {
        wait random {
1 { 1 } 1 { 0.5 } 1 { 0.1 } } seconds 
        if ! IsStreamPlaying PigeonFlyUpSound {
            if ! IsStreamPlaying PigeonIdleSound {
                random {
2 { 
 } 1 { Obj_PlayStream BO_Pigeon id=PigeonIdleSound vol=50 pitch=randomrange(95.0, 100.0) priority=StreamPriorityLowMid 
 } 1 { Obj_PlayStream BO_Pigeon_02 id=PigeonIdleSound vol=50 pitch=randomrange(95.0, 100.0) priority=StreamPriorityLowMid 
 } } 
            } 
        } 
    } 
} 
script AU_SFX_Pigeons_FlyUp {
    if IsStreamPlaying PigeonIdleSound {
        StopStream PigeonIdleSound 
    } 
    if IsStreamPlaying BO_Pigeon {
        StopStream BO_Pigeon 
    } 
    StopStream BO_PigeonFly 
    if ! IsStreamPlaying PigeonFlyUpSound {
        Obj_PlayStream BO_PigeonFly id=PigeonFlyUpSound vol=150 
    } 
} 


