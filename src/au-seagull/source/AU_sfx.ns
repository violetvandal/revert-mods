script AU_SFX_Seagull_Fly_Up {
    StopStream SeagullFlyUpStream 
    wait 1 gameframe 
    if ! IsStreamPlaying SeagullFlyUpStream {
        random {
1 { Obj_PlayStream AU_Seagull_Fly_Up_01 id=GullFlyUpSound vol=0 id=SeagullFlyUpStream 
 } 1 { Obj_PlayStream AU_Seagull_Fly_Up_02 id=GullFlyUpSound vol=0 id=SeagullFlyUpStream 
 } } 
    } 
} 
script AU_SFX_Metal_Detector_Beep {
    while {
        if ! IsStreamPlaying MetDetStream {
            random2 {
1 { Obj_PlayStream AU_Met_Detector_Beep_01 vol=100 priority=StreamPriorityLow dropoff=150 id=MetDetStream 
 } 1 { Obj_PlayStream AU_Met_Detector_Beep_02 vol=100 priority=StreamPriorityLow dropoff=150 id=MetDetStream 
 } } 
        } 
        wait 2 seconds 
    } 2 
} 
script AU_SFX_Metal_Detector_FindVO {
    Obj_StopStream MetDetStream 
    random2 {
1 { Obj_PlayStream AU_Met_Detector_Beep_01 vol=100 priority=StreamPriorityLow dropoff=150 id=MetDetStream 
 } 1 { Obj_PlayStream AU_Met_Detector_Beep_02 vol=100 priority=StreamPriorityLow dropoff=150 id=MetDetStream 
 } } 
    wait 2 seconds 
    random2 {
1 { Obj_PlayStream AU_Met_Det_Guy_Find_VO_01 vol=200 priority=StreamPriorityMid dropoff=150 id=MetDetStream 
 } 1 { Obj_PlayStream AU_Met_Det_Guy_Find_VO_02 vol=200 priority=StreamPriorityMid dropoff=150 id=MetDetStream 
 } 1 { Obj_PlayStream AU_Met_Det_Guy_Find_VO_03 vol=200 priority=StreamPriorityMid dropoff=150 id=MetDetStream 
 } } 
} 
script AU_SFX_Bridge_Reverb {
    if ! GameIsPaused {
        if ! InSplitScreenGame {
            if (inside) {
                
                change InsideAdjacentReverbBox01=1 
                GetValueFromVolume cdvol 
                if (InsideAdjacentReverbBox02 = 0) {
                    if (<value> = 0) {
                        SetSfxReverb 50 mode=REV_MODE_ROOM 
                    } else {
                        SetSfxReverb 60 mode=REV_MODE_ROOM 
                    } 
                } 
            } else {
                
                if (InsideAdjacentReverbBox02 = 0) {
                    SetSfxReverb 0 mode=REV_MODE_ROOM 
                } else {
                } 
                change InsideAdjacentReverbBox01=0 
            } 
        } 
    } 
} 
script AU_SFX_SecreteAreaReverb01 {
    if ! GameIsPaused {
        if ! InSplitScreenGame {
            if (inside) {
                
                change InsideAdjacentReverbBox01=1 
                GetValueFromVolume cdvol 
                if (InsideAdjacentReverbBox02 = 0) {
                    if (<value> = 0) {
                        SetSfxReverb 65 mode=REV_MODE_ROOM 
                    } else {
                        SetSfxReverb 80 mode=REV_MODE_ROOM 
                    } 
                } 
            } else {
                
                if (InsideAdjacentReverbBox02 = 0) {
                    SetSfxReverb 0 mode=REV_MODE_ROOM 
                } else {
                } 
                change InsideAdjacentReverbBox01=0 
            } 
        } 
    } 
} 
