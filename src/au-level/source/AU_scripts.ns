script AU_Gull {
    Obj_ShadowOff 
    Obj_ClearExceptions 
    Obj_SetException Ex=ObjectInRadius Scr=AU_Gull_Fly Params=<...> 
    Obj_SetInnerRadius 15 
    while {
        Obj_CycleAnim Anim=Idle NumCycles=random { 1 { 3 } 1 { 4 } 1 { 5 } 1 { 6 } 1 { 7 } 1 { 8 } 1 { 9 } 1 { 10 } } 
        Obj_CycleAnim Anim=FlyHop NumCycles=random { 1 { 1 } 1 { 2 } 1 { 3 } } 
    } 
} 
script AU_Gull_Fly {
    Obj_ClearExceptions 
    if GameModeEquals Is_Career {
        if GoalManager_GoalExists Name=AU_Goal_Gaps16 {
            <GullsScared> = 0 
            if ! GoalManager_GoalIsLocked Name=AU_Goal_Gaps16 {
                <do_count> = 0 
                if GetFlag flag=FLAG_GULL_COMBO {
                    <do_count> = 1 
                } 
                if GetGlobalFlag flag=MOD_AU_NO_GULL_COMBO {
                    <do_count> = 1 
                } 
                if (<do_count> = 1) {
                    if ! GoalManager_GoalFlagSet Name=AU_Goal_Gaps16 flag=<flag> {
                        GoalManager_SetGoalFlag Name=AU_Goal_Gaps16 <flag> 1 
                    } 
                    if GoalManager_GoalFlagSet Name=AU_Goal_Gaps16 flag=got_1 {
                        <GullsScared> = (<GullsScared> + 1) 
                    } 
                    if GoalManager_GoalFlagSet Name=AU_Goal_Gaps16 flag=got_2 {
                        <GullsScared> = (<GullsScared> + 1) 
                    } 
                    if GoalManager_GoalFlagSet Name=AU_Goal_Gaps16 flag=got_3 {
                        <GullsScared> = (<GullsScared> + 1) 
                    } 
                    if GoalManager_GoalFlagSet Name=AU_Goal_Gaps16 flag=got_4 {
                        <GullsScared> = (<GullsScared> + 1) 
                    } 
                    if GoalManager_GoalFlagSet Name=AU_Goal_Gaps16 flag=got_5 {
                        <GullsScared> = (<GullsScared> + 1) 
                    } 
                    if GoalManager_GoalFlagSet Name=AU_Goal_Gaps16 flag=Got_6 {
                        <GulsScared> = (<GullsScared> + 1) 
                    } 
                    if GoalManager_GoalFlagSet Name=AU_Goal_Gaps16 flag=Got_7 {
                        <GullsScared> = (<GullsScared> + 1) 
                    } 
                    if GoalManager_GoalFlagSet Name=AU_Goal_Gaps16 flag=Got_8 {
                        <GullsScared> = (<GullsScared> + 1) 
                    } 
                    if GoalManager_GoalFlagSet Name=AU_Goal_Gaps16 flag=Got_9 {
                        <GullsScared> = (<GullsScared> + 1) 
                    } 
                    if GoalManager_GoalFlagSet Name=AU_Goal_Gaps16 flag=Got_10 {
                        <GullsScared> = (<GullsScared> + 1) 
                    } 
                    if GoalManager_GoalFlagSet Name=AU_Goal_Gaps16 flag=Got_11 {
                        <GullsScared> = (<GullsScared> + 1) 
                    } 
                    if GoalManager_GoalFlagSet Name=AU_Goal_Gaps16 flag=Got_12 {
                        <GullsScared> = (<GullsScared> + 1) 
                    } 
                    if GoalManager_GoalFlagSet Name=AU_Goal_Gaps16 flag=Got_13 {
                        <GullsScared> = (<GullsScared> + 1) 
                    } 
                    if GoalManager_GoalFlagSet Name=AU_Goal_Gaps16 flag=Got_14 {
                        <GullsScared> = (<GullsScared> + 1) 
                    } 
                    if GoalManager_GoalFlagSet Name=AU_Goal_Gaps16 flag=Got_15 {
                        <GullsScared> = (<GullsScared> + 1) 
                    } 
                    if GoalManager_GoalFlagSet Name=AU_Goal_Gaps16 flag=Got_16 {
                        <GullsScared> = (<GullsScared> + 1) 
                    } 
                    if GoalManager_GoalFlagSet Name=AU_Goal_Gaps16 flag=Got_17 {
                        <GullsScared> = (<GullsScared> + 1) 
                    } 
                    if GoalManager_GoalFlagSet Name=AU_Goal_Gaps16 flag=Got_18 {
                        <GullsScared> = (<GullsScared> + 1) 
                    } 
                    if GoalManager_GoalFlagSet Name=AU_Goal_Gaps16 flag=Got_19 {
                        <GullsScared> = (<GullsScared> + 1) 
                    } 
                    if GoalManager_GoalFlagSet Name=AU_Goal_Gaps16 flag=Got_20 {
                        <GullsScared> = (<GullsScared> + 1) 
                    } 
                    if (<GullsScared> = 0) {
                        
                        Printf "CR CR CR --- NUM CANS = 0" 
                        
                    } else {
                        if (<GullsScared> = 1) {
                            
                            Create_Panel_Message {ID=Current_Goal text="1 Gull Scared! " Style=Goal_Collect_Text} 
                            
                        } else {
                            if (<GullsScared> = 2) {
                                
                                Create_Panel_Message {ID=Current_Goal text="2 Gulls Scared!" Style=Goal_Collect_Text} 
                                
                            } else {
                                if (<GullsScared> = 3) {
                                    
                                    Create_Panel_Message {ID=Current_Goal text="3 Gulls Scared!" Style=Goal_Collect_Text} 
                                    
                                } else {
                                    if (<GullsScared> = 4) {
                                        
                                        Create_Panel_Message {ID=Current_Goal text="4 Gulls Scared!" Style=Goal_Collect_Text} 
                                        
                                    } else {
                                        if (<GullsScared> = 5) {
                                            
                                            Create_Panel_Message {ID=Current_Goal text="5 Gulls Scared!" Style=Goal_Collect_Text} 
                                            
                                        } else {
                                            if (<GullsScared> = 6) {
                                                
                                                Create_Panel_Message {ID=Current_Goal text="6 Gulls Scared!" Style=Goal_Collect_Text} 
                                                
                                            } else {
                                                if (<GullsScared> = 7) {
                                                    
                                                    Create_Panel_Message {ID=Current_Goal text="7 Gulls Scared!" Style=Goal_Collect_Text} 
                                                    
                                                } else {
                                                    if (<GullsScared> = 8) {
                                                        
                                                        Create_Panel_Message {ID=Current_Goal text="8 Gulls Scared!" Style=Goal_Collect_Text} 
                                                        
                                                    } else {
                                                        if (<GullsScared> = 9) {
                                                            
                                                            Create_Panel_Message {ID=Current_Goal text="9 Gulls Scared!" Style=Goal_Collect_Text} 
                                                            
                                                        } else {
                                                            break 
                                                            
                                                        } 
                                                    } 
                                                } 
                                            } 
                                        } 
                                    } 
                                } 
                            } 
                        } 
                    } 
                } 
            } 
        } 
    } 
    if ! GetGlobalFlag flag=MOD_AU_SILENCE_GULLS {
        SpawnSound AU_SFX_Seagull_Fly_Up 
    } 
    Obj_PlayAnim Anim=Fly Cycle 
    Obj_MoveToRelPos (0.0, 250.0, 0.0) Speed=12 Acceleration=2 
    Obj_WaitMove 
    Obj_SetOuterRadius 20 
    Obj_SetException Ex=ObjectOutOfRadius Scr=AU_Gull_Return Params=<...> 
} 
script AU_Gull_Return {
    Obj_ClearExceptions 
    Obj_PlayAnim Anim=Fly Cycle 
    Obj_MoveToRelPos (0.0, -250.0, 0.0) Speed=8 Acceleration=2 
    Obj_WaitMove 
    GoToPreserveParams AU_Gull 
} 
script AU_GullComboListener {
    while {
        Printf "CR CR CR --- SETTING COMBO LISTENER" 
        WaitForEvent Type=SkaterEnterCombo 
        Printf "CR CR CR -- GOT COMBO START SO PROCEED AND SET --IN COMBO-- FLAG" 
        SetFlag flag=FLAG_GULL_COMBO 
        Printf "CR CR CR --- SETTING EXIT COMBO LISTENER" 
        WaitForEvent Type=SkaterExitCombo 
        Printf "CR CR CR -- GOT EXIT COMBO SO PROCEED AND UNSET --IN COMBO-- FLAG" 
        UnSetFlag flag=FLAG_GULL_COMBO 
        if GoalManager_GoalExists Name=AU_Goal_Gaps16 {
            if ! GoalManager_GoalIsLocked Name=AU_Goal_Gaps16 {
                GoalManager_ResetGoalFlags Name=AU_Goal_Gaps16 
            } 
        } 
    } 
} 
script AU_ShrimpWarp {
