script AU_Classic_GDAY_Message {
    <GDAY> = 0 
    if GoalManager_GoalFlagSet Name=AU_Classic_Goal_Gaps flag=got_1 {
        <GDAY> = (<GDAY> + 1) 
    } 
    if GoalManager_GoalFlagSet Name=AU_Classic_Goal_Gaps flag=got_2 {
        <GDAY> = (<GDAY> + 1) 
    } 
    if GoalManager_GoalFlagSet Name=AU_Classic_Goal_Gaps flag=got_3 {
        <GDAY> = (<GDAY> + 1) 
    } 
    if GoalManager_GoalFlagSet Name=AU_Classic_Goal_Gaps flag=got_4 {
        <GDAY> = (<GDAY> + 1) 
    } 
    if GoalManager_GoalFlagSet Name=AU_Classic_Goal_Gaps flag=got_5 {
        <GDAY> = (<GDAY> + 1) 
    } 
    if (<GDAY> = 0) {
        
        Printf "CR CR CR --- NUM GDay Gaps = 0" 
        
    } else {
        if (<GDAY> = 1) {
            
            Printf "CR CR CR --- NUM GDay Gaps = 1" 
            Create_Panel_Message {text="1 of 5 G'Day Gaps" Style=Goal_Collect_Text} 
            
        } else {
            if (<GDAY> = 2) {
                
                Printf "CR CR CR --- NUM GDay Gaps = 2" 
                Create_Panel_Message {text="2 of 5 G'Day Gaps" Style=Goal_Collect_Text} 
                
            } else {
                if (<GDAY> = 3) {
                    
                    Printf "CR CR CR --- NUM GDay Gaps = 3" 
                    Create_Panel_Message {text="3 of 5 G'Day Gaps" Style=Goal_Collect_Text} 
                    
                } else {
                    if (<GDAY> = 4) {
                        
                        Printf "CR CR CR --- NUM GDay Gaps = 4" 
                        Create_Panel_Message {text="4 of 5 G'Day Gaps" Style=Goal_Collect_Text} 
                        
                    } else {
                        break 
                        
                    } 
                } 
            } 
        } 
    } 
} 
