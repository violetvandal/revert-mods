script AU_Setup {
    AU_CreatePeds All 
    AU_Initializer 
} 
script AU_Initializer {
    AU_SecretArea_Off 
    if GameModeEquals Is_Career {
        if GoalManager_HasWonGoal Name=AU_Goal_Gaps6 {
            Create Name=AU_AS_MasterPiece_Final01 
        } 
        if ! GoalManager_HasWonGoal Name=AU_Goal_Gaps {
            Create Name=TRG_Ped_Hint_RampKid01 
            Kill Name=TRG_Ped_RampKid_Skate01 
        } 
        if ! GoalManager_HasWonGoal Name=AU_Goal_Gaps11 {
            Create Name=TRG_Ped_CornGuy01 
        } else {
            Create Name=TRG_Ped_CornGuy02 
        } 
        if ! GoalManager_HasWonGoal Name=Gaps13 {
            Create Name=TRG_Ped_Detector01 
        } else {
            Create Name=TRG_Ped_Detector03 
        } 
        if ! GoalManager_GoalIsLocked Name=AU_Goal_Gaps6 {
            if ! GoalManager_HasWonGoal Name=AU_Goal_Gaps6 {
                Create Name=TRG_Ped_GrafPunk01 
            } else {
                Create Name=TRG_Ped_GrafPunk02 
            } 
        } else {
            Create Name=TRG_Ped_GrafPunk02 
        } 
        if ! GoalManager_HasWonGoal Name=AU_Goal_Gaps10 {
            Create Prefix="TRG_Ped_Busted" 
        } 
        if ! GoalManager_HasWonGoal Name=AU_Goal_Gaps2 {
            Create Name=TRG_Ped_Foreman01 
        } else {
            if GoalManager_HasWonGoal Name=AU_Goal_Gaps10 {
            } else {
                if GoalManager_HasWonGoal Name=AU_Goal_Gaps3 {
                    Create Name=TRG_Ped_Foreman02 
                } 
            } 
        } 
        Create Name=TRG_Ped_Hawk01 
        Create Name=TRG_Ped_TeammatePro 
        if GoalManager_HasWonGoal Name=AU_Goal_Gaps11 {
            Create Name=TRG_Ped_ShrimpVendor 
        } else {
            Create Name=TRG_Ped_ShrimpVendorChill01 
        } 
        if GoalManager_HasWonGoal Name=AU_Goal_Gaps3 {
            Create Name=TRG_Ped_MiniKart01 
        } else {
            Create Name=TRG_Ped_Secret01 
        } 
        SpawnScript AU_ShrimpSlap_Counter Params={LastPedHit=asswipe} 
        CreateFastParticleSystem Name=JOW_AU_HydrantDrip01 params_Script=JOW_AU_HydrantDrip01_fast_particle_params 
    } 
    if InMultiPlayerGame {
        Kill Name=Geo_Crane_Obj_Arm 
        Kill Name=Geo_Crane_Obj_KennyHead 
        Kill Name=Geo_Crane_Obj_Chain 
        Create Name=Geo_NetGeo_CraneArm 
        Create Name=Geo_NetGeo_KennyHead 
        Create Name=Geo_NetGeo_Chain 
        Kill Name=Geo_ProximBox01 
        Kill Prefix="Geo_Secret" 
        Kill Prefix="TRG_L_Secret" 
        Kill Prefix="TRG_L_SecretFallsLip" 
        Kill Prefix="TRG_L_SecretPool" 
        Kill Prefix="TRG_R_SecretEntry" 
        Kill Prefix="TRG_R_SecretLadder" 
        Kill Name="Geo_TrashSpin01_Obj" 
        Kill Name="Geo_TrashSpin02_Obj" 
        Kill Name="Geo_TrashSpin03_Obj" 
        Create Prefix="Geo_MultiOn_TrashSpin" 
    } 
} 
script AU_Startup {
    SetFlag flag=FLAG_EVENT_A_PRE_STATE 
    LoadAsset "models\\gameobjects\\projectiles\\shrimp\\shrimp.tex" 
    LoadAsset "models\\gameobjects\\projectiles\\shrimp\\shrimp.mdl" parent=#a48d7426 
    LoadParticleTexture "bits\\CG_AU_Shatter_Pot" 
    LoadParticleTexture "bits\\CG_AU_Shatter_BlueFence" 
    LoadParticleTexture "bits\\CG_AU_Shatter_BeachSign" 
    LoadParticleTexture "bits\\CG_AU_Shatter_KangEar" 
    LoadParticleTexture "bits\\CG_AU_Shatter_KennyFinger" 
} 
script AU_Goals {
    if ! InMultiPlayerGame {
    } 
    if InMultiPlayerGame {
        Add_MultiPlayer_Mode_Goals 
    } 
    if ! InSplitScreenGame {
        if ((GameModeEquals is_classic) or (InNetGame)) {
            AddGoal_HighScore {
                unlimited_time 
                Score=AU_Classic_HighScore 
                Goal_Text=AU_Classic_HighScore_Text 
                View_Goals_Text=AU_Classic_HighScore_Text 
                Difficulty_Level_Params=[
                    {
                        Score=AU_Classic_Easy_HighScore 
                        Goal_Text=AU_Classic_Easy_HighScore_Text 
                        View_Goals_Text=AU_Classic_Easy_HighScore_Text 
                    } 
                    {
                        Score=AU_Classic_HighScore 
                        Goal_Text=AU_Classic_HighScore_Text 
                        View_Goals_Text=AU_Classic_HighScore_Text 
                    } 
                ] 
                view_goals_cameras=[{
                        Name=CAM_Classic_Intro01 
                        frames=301 
                        skippable=1 
                    } 
                ] 
                classic_mode_goal 
            } 
            AddGoal_ProScore {
                unlimited_time 
                Score=AU_Classic_ProScore 
                Goal_Text=AU_Classic_ProScore_Text 
                View_Goals_Text=AU_Classic_ProScore_Text 
                Difficulty_Level_Params=[
                    {
                        Score=AU_Classic_Easy_ProScore 
                        Goal_Text=AU_Classic_Easy_ProScore_Text 
                        View_Goals_Text=AU_Classic_Easy_ProScore_Text 
                    } 
                    {
                        Score=AU_Classic_ProScore 
                        Goal_Text=AU_Classic_ProScore_Text 
                        View_Goals_Text=AU_Classic_ProScore_Text 
                    } 
                ] 
                classic_mode_goal 
            } 
            AddGoal_SickScore {
                unlimited_time 
                Score=AU_Classic_SickScore 
                Goal_Text=AU_Classic_SickScore_Text 
                View_Goals_Text=AU_Classic_SickScore_Text 
                Difficulty_Level_Params=[
                    {
                        Score=AU_Classic_Easy_SickScore 
                        Goal_Text=AU_Classic_Easy_SickScore_Text 
                        View_Goals_Text=AU_Classic_Easy_SickScore_Text 
                    } 
                    {
                        Score=AU_Classic_SickScore 
                        Goal_Text=AU_Classic_SickScore_Text 
                        View_Goals_Text=AU_Classic_SickScore_Text 
                    } 
                ] 
                classic_mode_goal 
            } 
            AddGoal_HighCombo {
                unlimited_time 
                Score=AU_Classic_HighCombo 
                Goal_Text=AU_Classic_HighCombo_Text 
                View_Goals_Text=AU_Classic_HighCombo_Text 
