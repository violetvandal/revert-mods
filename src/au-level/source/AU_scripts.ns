script AU_Event_B {
    if InMultiPlayerGame {
    } else {
        if GetFlag flag=FLAG_EVENT_B_POST_STATE {
        } else {
            if GetFlag flag=FLAG_EVENT_A_POST_STATE {
                GetCurrentSkaterProfileIndex 
                GetSkaterProfileInfo Player=<CurrentSkaterProfileIndex> 
                Printf "CR CR CR --- Skater Name is %a" a=<Name> 
                if (<Name> = MiniKartDriver) {
                    GetTriggerArray Grind Onto 
                    if Triggertype <trigger_array> {
                        SetFlag flag=FLAG_EVENT_B_POST_STATE 
                        Wait 0.25 Seconds 
                        Kill Prefix="Geo_PreEvent_B" 
                        Kill Prefix="TRG_PreEvent_B" 
                        if ScreenElementExists ID=ped_speech_dialog {
                            DestroyScreenElement ID=ped_speech_dialog 
                        } 
                        PlayCutScene Name="CutScenes\\AU_LevelEvent2.Cut" RestartNode=TRG_Restart_Event_B 
                    } 
                } 
            } 
        } 
    } 
} 
script AU_Event_B_Out {
    Printf "CR CR CR --- GOT TO EVENT B OUT SCRIPT!!!" 
    Kill Prefix="Geo_PostEvent_A_Sway" 
    Kill Prefix="Geo_PreEvent_B" 
    Kill Prefix="TRG_PreEvent_B" 
    Kill Prefix="Geo_PostEvent_B" 
    Kill Prefix="TRG_PostEvent_B" 
    if IsAlive Name=NightOn_01_Geo_PreEvent_B_StreetLamp01 {
        Printf "CR CR CR --- Upright nighttime lampost is still alive, so kill it!" 
        Kill Name=NightOn_01_Geo_PreEvent_B_StreetLamp01 
    } 
    if IsAlive Name=NightOff_01_Geo_PreEvent_B_StreetLamp01 {
        Printf "CR CR CR --- Upright daytime lampost is still alive, so kill it!" 
        Kill Name=NightOff_01_Geo_PreEvent_B_StreetLamp01 
    } 
    if IsAlive Name=TRG_Ped_Foreman02 {
        Kill Name=TRG_Ped_Foreman02 
    } 
    if IsAlive Name=Geo_Crane_Obj_Chain {
        Kill Name=Geo_Crane_Obj_Chain 
    } 
    if IsAlive Name=Geo_Crane_Obj_KennyHead {
        Kill Name=Geo_Crane_Obj_KennyHead 
    } 
    Kill Name=NightOff_01_Geo_PreEvent_B_StreetLamp01 
    TODManager_MarkPermanentlyDead Name=NightOff_01_Geo_PreEvent_B_StreetLamp01 
    Kill Name=NightOn_01_Geo_PreEvent_B_StreetLamp01 
    TODManager_MarkPermanentlyDead Name=NightOn_01_Geo_PreEvent_B_StreetLamp01 
    Kill Name=NightOff_01_Geo_PreEvent_B_StreetLampGlobe 
    TODManager_MarkPermanentlyDead Name=NightOff_01_Geo_PreEvent_B_StreetLampGlobe 
    Kill Name=NightOn_01_Geo_PreEvent_B_StreetLampGlobe01 
    TODManager_MarkPermanentlyDead Name=NightOn_01_Geo_PreEvent_B_StreetLampGlobe01 
    if IsAlive Name=TRG_Night_LevelLight_01_Lamp68 {
        Kill Name=TRG_Night_LevelLight_01_Lamp68 
    } 
    TODManager_MarkPermanentlyDead Name=TRG_Night_LevelLight_01_Lamp68 
    Kill Name=NightOff_01_Geo_PreEvent_B_LampShadow 
    TODManager_MarkPermanentlyDead Name=NightOff_01_Geo_PreEvent_B_LampShadow 
    Create Prefix="Geo_PostEvent_B" 
    Create Prefix="TRG_PostEvent_B" 
    Printf "CR CR CR --- LAST OF CREATE/KILL OUT SCRIPT STUFF...MOVING TO GOAL CHECK!!!" 
    if GoalManager_GoalExists Name=AU_Goal_Gaps10 {
        if ! GoalManager_HasWonGoal Name=AU_Goal_Gaps10 {
            Printf "CR CR CR --- Goal Exists and is not beaten...spawn win goal stuff" 
            SpawnScript AU_Event_B_GoalEnd 
        } 
    } 
} 
script AU_Event_B_GoalEnd {
    Printf "CR CR CR --- GOT TO SPAWNED GOAL END SCRIPT SO PAUSE SKATERS" 
    PauseSkaters 
    Printf "CR CR CR --- JUST PAUSED SKATERS SO NOW PLAY CAMERA" 
    PlaySkaterCamAnim Name=CAM_BustedSkaters01 
    Kill Name=TRG_Ped_Cop01 
    Create Name=TRG_Ped_Cop02 
    Wait 2.5 Seconds 
    SendException EVENT_2_DONE Name=TRG_Ped_Busted01 
    SendException EVENT_2_DONE Name=TRG_Ped_Busted02 
    while {
        if SkaterCamAnimFinished Name=CAM_BustedSkaters01 {
            break 
        } 
        Wait 1 frames 
    } 
    Printf "CR CR CR --- CAMERA IS DONE SO UNPAUSE SKATERS" 
    GoalManager_SetGoalFlag Name=AU_Goal_Gaps10 got_1 1 
    UnPauseSkaters 
} 
script AU_Event_B_GoalDone {
    UnPauseSkaters 
} 
