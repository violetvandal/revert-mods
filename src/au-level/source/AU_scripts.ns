script AU_2d_sign_element_create {parent = menu3d_anchor 
    if GetGlobalFlag flag=SCREEN_MODE_WIDE {
        <offset> = (-8.0, 0.0) 
    } else {
        <offset> = (0.0, 0.0) 
    } 
    CreateScreenElement {
        Type=SpriteElement 
        parent=<parent> 
        texture=AU_icon_1 
        ID=AU_turtle 
        scale=3.5 
        rgba=[128 128 128 100] 
        pos=((220.0, 310.0) + <offset>) 
        rot_angle=0 
        just=[center center] 
        z_priority=-51 
    } 
    flame_angle = -90 
    CreateScreenElement {
        Type=SpriteElement 
        parent=<parent> 
        texture=AU_icon_2 
        ID=AU_flame 
        scale=2.2 
        rgba=[124 45 23 128] 
        pos=((76.0, 182.0) + <offset>) 
        rot_angle=<flame_angle> 
        just=[center bottom] 
        z_priority=-51 
    } 
    RunScriptOnScreenElement ID=AU_turtle AU_turtle_anim 
    RunScriptOnScreenElement ID=AU_flame AU_flame_anim 
} 
script AU_flame_anim {
    while {
        new_pt = random { 1 { (150.0, 215.0) } 1 { (76.0, 182.0) } 1 { (115.0, 152.0) } 1 { (198.0, 192.0) } } 
        DoMorph time=0 scale=2.2 pos=<new_pt> alpha=1 
        while {
            DoMorph time=0 alpha=1 
            DoMorph time=0.08 alpha=random { 1 { 0.4 } 1 { 0.5 } 1 { 0.8 } } rot_angle=random { 1 { -89 } 1 { -91 } } 
        } random { 1 { 10 } 1 { 15 } 1 { 20 } } 
        DoMorph time=1.5 scale=2.5 pos=(<new_pt> + (5.0, -15.0)) alpha=0 rot_angle=-90 
        Wait random { 1 { 1 } 1 { 2 } 1 { 3 } } Seconds 
    } 
} 
script AU_turtle_anim {
    while {
        DoMorph time=0 rot_angle=-3 
        DoMorph time=0.2 rot_angle=3 
        DoMorph time=0.3 rot_angle=-3 
    } 
} 
script AU_EnterSand {
    change SFX_FootStepWalk01=AU_SANDSTEP01 
    change SFX_FootStepWalk02=AU_SANDSTEP02 
    change SFX_FootStepWalk03=AU_SANDSTEP03 
    change SFX_FootStepRun01=AU_SANDSTEP01 
    change SFX_FootStepRun02=AU_SANDSTEP02 
    change SFX_FootStepRun03=AU_SANDSTEP03 
    change SFX_FootStepRun04=AU_SANDSTEP01 
    change SFX_FootStepRun05=AU_SANDSTEP02 
    if ! GetGlobalFlag flag=MOD_AU_SKATE_SAND {
        ForceToWalk 
    } 
} 
script AU_ExitSand {
    SFX_Change_Footstep_Sounds_To_Default 
    KillForceToWalk 
} 
script AU_WaterKill {
    SFX_Change_Footstep_Sounds_To_Default 
    SK3_KillSkater nodename=<nodename> 
} 
