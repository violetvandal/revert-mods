    UnSetFlag flag=FLAG_LOFTY_GAP_GOT 
    UnSetFlag flag=FLAG_LOFTY_GAP_TRICK_GOT 
    GoTo AU_LoftyGap_TrickWait 
} 
script AU_Gap_JumpFan_End {
    EndGap GapID=JumpFan Score=150 text="Lofty Roof Gap" 
    SetFlag flag=FLAG_LOFTY_GAP_GOT 
} 
script AU_LoftyGap_TrickWait {
    ClearExceptionGroup LoftyGapGroup 
    SetException Ex=SkaterTrickDisplayed Scr=AU_LoftyGap_TrickCheck Group=LoftyGapGroup 
    SetException Ex=SkaterEnterManual Scr=AU_LoftyGap_Landed Group=LoftyGapGroup 
    SetException Ex=SkaterEnterRevert Scr=AU_LoftyGap_Landed Group=LoftyGapGroup 
    SetException Ex=SkaterEnterGround Scr=AU_LoftyGap_Landed Group=LoftyGapGroup 
    SetException Ex=SkaterBailed Scr=AU_LoftyGap_Bailed Group=LoftyGapGroup 
    Block 
} 
script AU_LoftyGap_TrickCheck {
    ClearExceptionGroup LoftyGapGroup 
    GetNumberOfTrickOccurrences TrickText="Rotisserie" 
    if (<Number_Of_Occurrences> > 1) {
        SetFlag flag=FLAG_LOFTY_GAP_TRICK_GOT 
        SetException Ex=SkaterEnterManual Scr=AU_LoftyGap_Landed Group=LoftyGapGroup 
        SetException Ex=SkaterEnterRevert Scr=AU_LoftyGap_Landed Group=LoftyGapGroup 
        SetException Ex=SkaterEnterGround Scr=AU_LoftyGap_Landed Group=LoftyGapGroup 
        SetException Ex=SkaterBailed Scr=AU_LoftyGap_Bailed Group=LoftyGapGroup 
        Block 
    } 
    GoTo AU_LoftyGap_TrickWait 
} 
script AU_LoftyGap_Landed {
    ClearExceptionGroup LoftyGapGroup 
    if GoalManager_GoalExists Name=AU_Goal_Gaps15 {
        Wait 10 frames 
        if GetFlag flag=FLAG_LOFTY_GAP_GOT {
            if GetFlag flag=FLAG_LOFTY_GAP_TRICK_GOT {
                GoalManager_SetGoalFlag Name=AU_Goal_Gaps15 got_1 1 
            } 
        } 
    } 
    UnSetFlag flag=FLAG_LOFTY_GAP_GOT 
    UnSetFlag flag=FLAG_LOFTY_GAP_TRICK_GOT 
} 
script AU_LoftyGap_Bailed {
    ClearExceptionGroup LoftyGapGroup 
    UnSetFlag flag=FLAG_LOFTY_GAP_GOT 
    UnSetFlag flag=FLAG_LOFTY_GAP_TRICK_GOT 
} 
script AU_AddGoal_ShrimpSlap {
