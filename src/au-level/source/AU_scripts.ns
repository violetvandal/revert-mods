script BE_STATECONTROL_Grilling {
    while {
        random {
1 { PlayAnimWithPartialAnimIfExists Anim=Ped_Griller_Cooking01 
 } 1 { PlayAnimWithPartialAnimIfExists Anim=Ped_Griller_Cooking02 
 } 1 { PlayAnimWithPartialAnimIfExists Anim=Ped_Griller_FixesGrill 
 } 1 { PlayAnimWithPartialAnimIfExists Anim=Ped_Griller_LooksAround 
 } 1 { PlayAnimWithPartialAnimIfExists Anim=Ped_Griller_Stretch 
 } 1 { PlayAnimWithPartialAnimIfExists Anim=Ped_Griller_CallingCustomers 
 } } 
        Obj_WaitAnimFinished 
    } 
} 
script PEDAI_MetalDetectStopWaypoint {
    Ped_SetLogicState AU_STATE_MetalDetect_Standing Table=AU_MetalDetectLogic_Table 
} 
script AU_Ped_Detector_Talk {
    Ped_SetLogicState AU_STATE_MetalDetect_Talking Table=AU_MetalDetectLogic_Table 
} 
script AU_STATECONTROL_MetalDetect_Walking {
    GetTags 
    OBJ_EnableAnimBlending enabled=1 
    while {
        PlayAnimWithPartialAnimIfExists Anim=Ped_MetalDetect_WalkCyle 
        Obj_WaitAnimFinished 
    } 
} 
script AU_STATECONTROL_MetalDetect_Standing {
    Ped_StopMoving 
    PlayAnimWithPartialAnimIfExists Anim=Ped_MetalDetect_WalkCyleStop 
    Obj_WaitAnimFinished 
    GetRandomValue Name=RepeatCount a=1 b=3 resolution=3 Integer 
    while {
        random {
1 { PlayAnimWithPartialAnimIfExists Anim=Ped_MetalDetect_Idle01 
        SpawnSound AU_SFX_Metal_Detector_Beep 
 } 1 { PlayAnimWithPartialAnimIfExists Anim=Ped_MetalDetect_PicksUpCoin 
        SpawnSound AU_SFX_Metal_Detector_FindVO 
 } } 
        Obj_WaitAnimFinished 
    } <RepeatCount> 
    Ped_StartMoving 
    PlayAnimWithPartialAnimIfExists Anim=Ped_MetalDetect_StartWalkCycle 
    Obj_WaitAnimFinished 
    Ped_SetLogicState AU_STATE_MetalDetect_Walking Table=AU_MetalDetectLogic_Table 
} 
script AU_STATECONTROL_MetalDetect_Talking {
    Ped_StopMoving 
    PlayAnimWithPartialAnimIfExists Anim=Ped_MetalDetect_WalkCyleStop 
    Obj_WaitAnimFinished 
    GetRandomValue Name=RepeatCount a=1 b=3 resolution=3 Integer 
    while {
        Printf "---------------------------------METAL DETECTOR TALKING--------------------------------------" 
        PlayAnimWithPartialAnimIfExists Anim=Ped_MetalDetect_Idle01 
        Obj_WaitAnimFinished 
    } <RepeatCount> 
    Ped_StartMoving 
    PlayAnimWithPartialAnimIfExists Anim=Ped_MetalDetect_StartWalkCycle 
    Obj_WaitAnimFinished 
    Ped_SetLogicState AU_STATE_MetalDetect_Walking Table=AU_MetalDetectLogic_Table 
} 
script AU_STATECONTROL_RampKid {
    while {
        GetRandomValue Name=RepeatCount a=1 b=3 resolution=3 Integer 
        while {
            random {
2 { PlayAnimWithPartialAnimIfExists Anim=Ped_RampKid_Idle01 
 } 1 { PlayAnimWithPartialAnimIfExists Anim=Ped_RampKid_Looking 
 } } 
            Obj_WaitAnimFinished 
        } <RepeatCount> 
        PlayAnimWithPartialAnimIfExists Anim=Ped_RampKid_PutBoardDown 
        Obj_WaitAnimFinished 
        GetRandomValue Name=RepeatCount a=1 b=3 resolution=3 Integer 
        while {
            random {
1 { PlayAnimWithPartialAnimIfExists Anim=Ped_RampKid_BrdDwnLooks 
 } 1 { PlayAnimWithPartialAnimIfExists Anim=Ped_RampKid_BrdDwnHelmet 
 } 1 { Printf "Rampkid skip" 
 } } 
            Obj_WaitAnimFinished 
        } <RepeatCount> 
        PlayAnimWithPartialAnimIfExists Anim=Ped_RampKid_PickUpBrd 
        Obj_WaitAnimFinished 
    } 
} 
script AU_STATECONTROL_Minikart {
    while {
        PlayAnimWithPartialAnimIfExists Anim=Veh_Minikart_Idle 
        Obj_WaitAnimFinished 
    } 
} 
script AU_STATECONTROL_Minikart_Standing {
    PlayAnimWithPartialAnimIfExists Anim=Veh_Minikart_Ollie 
    Obj_WaitAnimFinished 
    PlayAnimWithPartialAnimIfExists Anim=Veh_Minikart_Land 
    Obj_WaitAnimFinished 
    while {
        PlayAnimWithPartialAnimIfExists Anim=Veh_Minikart_Idle 
        Obj_WaitAnimFinished 
    } 
} 
script PEDAI_LifeGuard_StopWayPoint {
    Ped_StopMoving 
    Ped_GetCurrentNodeNames 
    Obj_MoveToNode Name=<node_from> Speed=5 mph 
    Obj_WaitMove 
    Ped_StartMoving 
    Ped_SetLogicState AU_STATE_LifeGuard_Scanning Table=AU_StateLogic_Table 
} 
script AU_STATECONTROL_Lifeguard_Scanning {
    Ped_TurnToCurrentWaypointOrientation time=0.75 
    PlayAnimWithPartialAnimIfExists Anim=WWalkToStand 
    Obj_WaitAnimFinished 
    while {
        random {
1 { PlayAnimWithPartialAnimIfExists Anim=WStandIdle2 
 } 1 { PlayAnimWithPartialAnimIfExists Anim=WStandIdle3 
 } 1 { PlayAnimWithPartialAnimIfExists Anim=WStandIdle4 
 } } 
        Obj_WaitAnimFinished 
    } 5 
    Ped_Statelogic_SetDefaultState 
} 
script AU_STATECONTROL_Lifeguard_Walking {
    PlayAnimWithPartialAnimIfExists Anim=WWalkToStand 
    Obj_WaitAnimFinished 
    while {
        PlayAnimWithPartialAnimIfExists Anim=WWalk 
        Obj_WaitAnimFinished 
    } 
} 
script AU_STATECONTROL_Cop_pissed {
    obj_getID 
    <ObjID>:SwitchOnAtomic ped_m_accessories 
    <ObjID>:SwitchOffAtomic ped_Board 
    while {
        random {
1 { PlayAnimWithPartialAnimIfExists Anim=PED_M_Pissed01 
 } 1 { PlayAnimWithPartialAnimIfExists Anim=PED_M_Pissed02 
 } 1 { PlayAnimWithPartialAnimIfExists Anim=PED_M_Pissed03 
 } 1 { PlayAnimWithPartialAnimIfExists Anim=PED_M_Pissed04 
 } } 
        Obj_WaitAnimFinished 
    } 
} 
