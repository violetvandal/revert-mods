        Create_Panel_Message {text=random { 1 { "Gonna get wet!!!" } 1 { "Where are you going??" } 1 { "Heading for trouble!" } } Style=Goal_Collect_Text ID=wetwarning} 
        TRG_SFX_Ghost_LifeguardYelling:Obj_StopStream LifeguardStream 
