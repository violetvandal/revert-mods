script AU_TrashCanRotate_Signal {
    if InMultiPlayerGame {
    } else {
        SendException CAN_SPIN_START Name=<Can> 
    } 
} 
script AU_TrashCanRotate_Wait {
    Obj_ClearExceptions 
    Obj_SetException Ex=CAN_SPIN_START Scr=AU_TrashCanRotate Params=<...> 
} 
script AU_TrashCanRotate {
    Obj_RotZ Angle=2160 Speed=360 FLAG_MAX_COORDS 
    if ! InMultiPlayerGame {
        if IsAlive Name=<Trash1> {
            Kill Name=<Trash1> 
        } 
        if IsAlive Name=<Trash2> {
            Kill Name=<Trash2> 
        } 
        if IsAlive Name=<Trash3> {
            Kill Name=<Trash3> 
        } 
        if GoalManager_GoalIsLocked Name=AU_Goal_Gaps13 {
            Printf "CR CR CR --- TRASH GOAL IS LOCKED SO SODA CAN OK" 
            Create Name=<Trash1> 
            <Trash1>:Rigidbody_DisablePlayerCollision 
            <Trash1>:Rigidbody_Kick Vel=(0.0, 15.0, 5.0) RotVel=(5.0, 5.0, 5.0) 
            <Trash1>:Rigidbody_MatchVelocityTo Skater ApplyRandomAdjustment 
        } 
        Create Name=<Trash2> 
        <Trash2>:Rigidbody_DisablePlayerCollision 
        <Trash2>:Rigidbody_Kick Vel=(20.0, 30.0, 0.0) RotVel=(7.0, 7.0, 7.0) 
        <Trash2>:Rigidbody_MatchVelocityTo Skater ApplyRandomAdjustment 
        Create Name=<Trash3> 
        <Trash3>:Rigidbody_DisablePlayerCollision 
        <Trash3>:Rigidbody_Kick Vel=(20.0, 30.0, 0.0) RotVel=(7.0, 7.0, 7.0) 
        <Trash3>:Rigidbody_MatchVelocityTo Skater ApplyRandomAdjustment 
        SpawnScript AU_CanPickup Params=<...> 
    } 
    Obj_WaitRotate 
    GoToPreserveParams AU_TrashCanRotate_Wait 
} 
script AU_CanPickup {
    if GoalManager_GoalExists Name=AU_Goal_Gaps13 {
        <TinCans> = 0 
        if ! GoalManager_GoalIsLocked Name=AU_Goal_Gaps13 {
            if ! GoalManager_HasWonGoal Name=AU_Goal_Gaps13 {
                if ! GoalManager_GoalFlagSet Name=AU_Goal_Gaps13 flag=<flag> {
                    GoalManager_SetGoalFlag Name=AU_Goal_Gaps13 <flag> 1 
                    if GoalManager_GoalFlagSet Name=AU_Goal_Gaps13 flag=got_1 {
                        <TinCans> = (<TinCans> + 1) 
                    } 
                    if GoalManager_GoalFlagSet Name=AU_Goal_Gaps13 flag=got_2 {
                        <TinCans> = (<TinCans> + 1) 
                    } 
                    if GoalManager_GoalFlagSet Name=AU_Goal_Gaps13 flag=got_3 {
                        <TinCans> = (<TinCans> + 1) 
                    } 
                    if (<TinCans> = 0) {
                        
                        Printf "CR CR CR --- NUM CANS = 0" 
                        
                    } else {
                        if (<TinCans> = 1) {
                            
                            Printf "CR CR CR --- NUM CANS = 1" 
                            Create_Panel_Message {text="1 of 3 Cans Collected" Style=Goal_Collect_Text} 
                            
                        } else {
                            if (<TinCans> = 2) {
                                
                                Printf "CR CR CR --- NUM CANS = 2" 
                                Create_Panel_Message {text="2 of 3 Cans Collected" Style=Goal_Collect_Text} 
                                
                            } else {
                                if (<TinCans> = 3) {
                                    
                                    Printf "CR CR CR --- NUM CANS = 3" 
                                    Create_Panel_Message {text="3 Cans! Now Go See Hank!" Style=Goal_Collect_Text} 
                                    Kill Name=TRG_Ped_Detector01 
                                    Create Name=TRG_Ped_Detector02 
                                    
                                } else {
                                    break 
                                    
                                } 
                            } 
                        } 
                    } 
                } 
            } else {
                Printf "CR CR CR --- Trash Goal HAS been beaten" 
            } 
        } else {
            Printf "CR CR CR --- Trash Goal IS locked" 
        } 
    } 
} 
script AU_SignSlam {
    if GoalManager_GoalExists Name=AU_Goal_Gaps17 {
        GoalManager_SetGoalFlag Name=AU_Goal_Gaps17 <flag> 1 
    } 
    PlaySound AU_HitHandiSign vol=150 
    Kill Name=<Sign> 
    Kill Name=<Shadow> 
    Create Name=<Jacked> 
    <Jacked>:Rigidbody_DisablePlayerCollision 
    <Jacked>:Rigidbody_Kick Vel=(0.0, 15.0, 5.0) RotVel=(5.0, 5.0, 5.0) 
    <Jacked>:Rigidbody_MatchVelocityTo Skater ApplyRandomAdjustment 
} 
script AU_SwitchSkaters {
    KillSpawnedScript Name=AU_Spawn_SwitchSkaters 
    SpawnSkaterScript AU_Spawn_SwitchSkaters 
} 
script AU_Spawn_SwitchSkaters {
    Wait 2 frames 
    Pulse_Blur 
    swap_skaters_get_current_name 
    if (<Name> = Custom) {
        
        Skater:Obj_StopStream ShrimperCooking 
        TakeOver_VO 
        
    } else {
        if (<Name> = MiniKartDriver) {
            
            Skater:Obj_StopStream ShrimperCooking 
            SetGlobalFlag flag=GUEST_FOUND_ABORIGINE 
            AU_Unlock_Aborigine_Goals 
            
        } else {
            if (<Name> = pro_teammate) {
                
                SetGlobalFlag flag=PRO_FOUND_04 
                AU_Unlock_Pro_Goals 
                
            } else {
                if (<Name> = ShrimpVendor) {
                    
                    SetGlobalFlag flag=GUEST_FOUND_SHRIMPVENDOR 
                    SetGlobalFlag flag=SKATER_UNLOCKED_SHRIMPVENDOR 
                    AU_Unlock_Shrimp_Goals 
                    
                } 
            } 
        } 
    } 
} 
script AU_Unlock_Pro_Goals {
    if ! IsAlive Name=TRG_Ped_GrafPunk01 {
        Create Name=TRG_Ped_GrafPunk01 
        if IsAlive Name=TRG_Ped_GrafPunk02 {
            Kill Name=TRG_Ped_GrafPunk02 
        } 
    } 
    if GoalManager_GoalIsLocked Name=AU_Goal_Gaps7 {
        if ScreenElementExists ID=ped_speech_dialog {
            DestroyScreenElement ID=ped_speech_dialog 
        } 
        Printf "play cameras" 
        play_swappable_pro_intro_cameras intro_cameras=AU_Pro_Goal_Intro_Cameras 
        GoalManager_UnlockGoal Name=AU_Goal_Gaps7 
        GoalManager_UnlockGoal Name=AU_Goal_Gaps8 
        GoalManager_UnlockGoal Name=AU_Goal_Gaps9 
        GoalManager_UnlockGoal Name=AU_Goal_Gaps21 
        GoalManager_UnlockGoal Name=AU_Goal_Gaps4 
        GoalManager_UnlockGoal Name=AU_Goal_Gaps6 
        GoalManager_UnlockGoal Name=AU_Goal_Gaps13 
        GoalManager_UnlockGoal Name=AU_Goal_Gaps19 
    } else {
        TakeOver_VO 
    } 
} 
script AU_Unlock_Shrimp_Goals {
    DestroyFlexibleParticleSystem Name=GrillFireParticleSystemLow 
    DestroyFlexibleParticleSystem Name=GrillFireParticleSystem 
    DestroyFlexibleParticleSystem Name=GrillSmokeParticleSystem 
    if GoalManager_GoalIsLocked Name=AU_Goal_Gaps14 {
        if ScreenElementExists ID=ped_speech_dialog {
            DestroyScreenElement ID=ped_speech_dialog 
        } 
        Printf "play cameras" 
        Create Name=TRG_Ped_ShrimpVendor_Intro 
        PlayIntroCameras goal_intro_cameras=AU_Shrimp_Goal_Intro_Cameras letterbox 
        Kill Name=TRG_Ped_ShrimpVendor_Intro 
        GoalManager_UnlockGoal Name=AU_Goal_Gaps14 
        GoalManager_UnlockGoal Name=AU_Goal_Gaps15 
        GoalManager_UnlockGoal Name=AU_Goal_Gaps18 
        GoalManager_UnlockGoal Name=AU_Goal_Gaps16 
        AwardNewSpecialTrickToProfile {
            all_profiles 
            trick=Trick_Rotisserie 
            key_combo=SpAir_L_D_Circle 
        } 
    } else {
        TakeOver_VO 
    } 
} 
