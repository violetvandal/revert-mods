script AU_MiniLip {
    GetTriggerArray Lip Onto 
    if Triggertype <trigger_array> {
        Printf "CR CR CR GOT LIP ONTO...Setting Exceptions." 
        ClearExceptionGroup AU_MiniLipGroup 
        SetException Ex=SkaterLanded Scr=AU_MiniLip_Got Group=AU_MiniLipGroup 
        SetException Ex=SkaterBailed Scr=AU_MiniLip_Fail Group=AU_MiniLipGroup 
        Block 
    } 
} 
script AU_MiniLip_Got {
    ClearExceptionGroup AU_MiniLipGroup 
    if GoalManager_GoalExists Name=AU_Goal_Gaps {
        if ! GoalManager_HasWonGoal Name=AU_Goal_Gaps {
            GoalManager_GetDifficultyLevel 
            if (<Difficulty_Level> = 0) {
                
                MiniScore = AU_Mini_Score_Easy 
                
            } else {
                if (<Difficulty_Level> = 1) {
                    
                    MiniScore = AU_Mini_Score_Normal 
                    
                } else {
                    if (<Difficulty_Level> = 2) {
                        
                        MiniScore = AU_Mini_Score_Hard 
                        
                    } 
                } 
            } 
            if SkaterLastScoreLandedGreaterThan <MiniScore> {
                GoalManager_SetGoalFlag Name=AU_Goal_Gaps got_1 1 
                Create Name=TRG_Ped_RampKid_Skate01 
                Kill Name=TRG_Ped_Hint_RampKid01 
            } 
        } 
    } 
} 
script AU_MiniLip_Fail {
    ClearExceptionGroup AU_MiniLipGroup 
} 
