} 
script AU_TidePoolPump_Grind {
    if ! InNetGame {
        if IsAlive Name=Geo_TidePoolPump01 {
            GetBonus Score=1000 text="Destruction Bonus" 
            Create Name=Geo_TidePoolPump01_Broken 
            Create Prefix="Particle_TP" 
            Kill Name=TRG_SFX_TrigBox_SwitchBreakElectric 
            Create Name=TRG_SFX_TrigBox_SwitchBreakElectric 
            SpawnScript AU_SFX_DrainPool 
            Kill Name=Geo_TidePoolPump01 
            Geo_TidePoolWater:Obj_MoveToRelPos (0.0, -1000.0, 0.0) Speed=0.5 
            Kill Name=Geo_Inv_Coll_TidePoolFloorParticle 
            if GoalManager_GoalExists Name=AU_Goal_Gaps5 {
                if ! GoalManager_HasWonGoal Name=AU_Goal_Gaps5 {
                    GoalManager_SetGoalFlag Name=AU_Goal_Gaps5 got_1 1 
                } 
            } 
        } 
    } else {
        Geo_TidePoolWater:Obj_MoveToRelPos (0.0, -1000.0, 0.0) Speed=0.5 
        Kill Name=Geo_Inv_Coll_TidePoolFloorParticle 
    } 
} 
script AU_TidePoolPump_WallPlant {
    GetTriggerArray Wallplant Onto 
    if Triggertype <trigger_array> {
        if IsAlive Name=Geo_TidePoolPump01 {
            SendException PUMP_BREAK Name=TRG_TidePoolPump_Ghost01 
            GetBonus Score=1000 text="Destruction Bonus" 
        } 
    } 
} 
script AU_TidePoolPump_Ghost {
    Obj_ClearExceptions 
    Obj_SetException Ex=PUMP_BREAK Scr=AU_TidePoolPump_Break 
} 
script AU_TidePoolPump_Break {
    Kill Name=Geo_TidePoolPump01 
    Create Name=Geo_TidePoolPump01_Broken 
    Create Prefix="Particle_TP" 
    Kill Name=Geo_Inv_Coll_TidePoolFloorParticle 
    Geo_TidePoolWater:Obj_MoveToRelPos (0.0, -1000.0, 0.0) Speed=0.5 
    if GoalManager_GoalExists Name=AU_Goal_Gaps5 {
        if ! GoalManager_HasWonGoal Name=AU_Goal_Gaps5 {
            GoalManager_SetGoalFlag Name=AU_Goal_Gaps5 got_1 1 
        } 
    } 
} 
