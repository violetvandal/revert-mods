script AU_AddGoal_BeverHausen {
    AddGoal_gaps {
        version=22 
        Silent_Activation 
        Skater=Custom 
        Reward_Points=500 
        collect_type="Beaver Blasts" 
        View_Goals_Text=AU_Construction_text 
        goal_description=AU_Construction_Desc 
        view_goals_notify_trick=Trick_BeaverBlast 
        Goal_Success_Script=AU_goal_BeaverBlast_Success 
        view_goals_cameras=[
            {
                targetOffset=(-14170.2, 587.2, 13521.8) 
                positionOffset=(-5308.0, 443.7, 8891.5) 
            } 
        ] 
        goal_flags=[got_1 
            got_2 
            got_3 
            got_4 
            got_5 
        ] 
    } 
} 
script AU_Beaver_Construction {
    Obj_EnableAmbientLight 
    Obj_EnableDiffuseLight index=0 
    Obj_EnableDiffuseLight index=1 
    Obj_SetLightAmbientColor r=200 g=200 b=200 
    Obj_SetLightDiffuseColor index=0 r=0 g=0 b=0 
    Obj_SetLightDiffuseColor index=1 r=0 g=0 b=0 
    Ped_InitAI Fall 
} 
script AU_Beaver_Ghost_Wait {
    Obj_ClearExceptions 
    Obj_SetInnerRadius 30 
    Obj_SetException Ex=ObjectInRadius Scr=AU_Beaver_Ghost_Near Params=<...> 
    Printf "AU_Beaver_Ghost_Wait" 
} 
script AU_Beaver_Ghost_Near {
    Obj_ClearExceptions 
    Obj_SetOuterRadius 35 
    Obj_SetException Ex=ObjectOutOfRadius Scr=AU_Beaver_Ghost_Wait Params=<...> 
    Obj_SetException Ex=AU_Beaver_Blast Scr=AU_Beaver_Ghost_Burn Params=<...> 
    Printf "AU_Beaver_Ghost_Near" 
} 
script AU_Beaver_Ghost_Burn {
    Obj_ClearExceptions 
    GoalManager_SetGoalFlag Name=AU_Goal_Gaps22 <flag> 1 
    CreateFlexibleParticleSystem {
        ObjID=<worker> 
        Name=BurningHead 
        params_Script=APM_flaming_HEAD_particle_params 
    } 
    <worker>:Ped_SetLogicState BE_STATE_Cop_OnFire Table=BE_CopLogic_Table 
    <worker>:Obj_EnableAmbientLight 
    <worker>:Obj_EnableDiffuseLight index=0 
    <worker>:Obj_EnableDiffuseLight index=1 
    <worker>:Obj_SetLightAmbientColor r=50 g=50 b=50 
    <worker>:Obj_SetLightDiffuseColor index=0 r=0 g=0 b=0 
    <worker>:Obj_SetLightDiffuseColor index=1 r=0 g=0 b=0 
    Printf "Got a fart 2" 
    Die 
} 
script AU_AddGoal_BeverHausen2 {
    AddGoal_gaps {
        version=23 
        Silent_Activation 
        Skater=Custom 
        Reward_Points=500 
        View_Goals_Text=AU_Bikini_text 
        goal_description=AU_Bikini_Desc 
        No_Gap_Messages 
        Goal_Success_Script=AU_Goal_Gaps23_Success 
        view_goals_cameras=[
            {
                targetOffset=(4829.6, -5861.2, 7472.2) 
                positionOffset=(-2806.7, 244.7, 5377.0) 
            } 
        ] 
        success_cam_anims=[
            {virtual_cam 
                targetid=world 
                targetOffset=(3682.8, -1842.1, -2226.3) 
                positionOffset=(-2507.2, -204.6, 5455.0) 
                frames=100 
                skippable=1 
                pre_anim_script=AU_Goal_Gaps23_Pre_Success 
                cam_anim_text=["Rack off you wally!  You got bird crap all over me! " 
