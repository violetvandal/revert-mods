script AU_Hydrant_Counter {
    SetException Ex=SkaterJump Scr=AU_Hydrant_Counter_Kill 
    SetException Ex=SkaterBailed Scr=AU_Hydrant_Counter_Kill 
    Wait 1 Second 
    Create_Panel_Message {text="Keep Spinning - 3!" Style=Goal_Collect_Text} 
    Wait 1 Second 
    Create_Panel_Message {text="Keep Spinning - 2!" Style=Goal_Collect_Text} 
    Wait 1 Second 
    Create_Panel_Message {text="Keep Spinning - 1!" Style=Goal_Collect_Text} 
    Wait 1 Second 
    Create_Panel_Message {text="FIRE IN THE HOLE!" Style=Goal_Collect_Text} 
    Wait 1 Second 
    UnSetFlag flag=FLAG_EVENT_A_PRE_STATE 
    SetFlag flag=FLAG_EVENT_A_POST_STATE 
    AU_Event_A 
} 
