script AU_GotAwningGrind {
    if GoalManager_GoalExists Name=AU_Goal_Gaps19 {
        GetCurrentSkaterProfileIndex 
        GetSkaterProfileInfo Player=<CurrentSkaterProfileIndex> 
        Printf "CR CR CR --- Skater Name is %a" a=<Name> 
        <Awning_Grinds> = 0 
        if ! GoalManager_GoalIsLocked Name=AU_Goal_Gaps19 {
            if (<skater_family> = family_pro) {
                if ! GoalManager_GoalFlagSet Name=AU_Goal_Gaps19 flag=got_1 Skater=Pro {
                    GoalManager_SetGoalFlag Name=AU_Goal_Gaps19 got_1 1 Skater=Pro 
                } 
            } else {
                if (<Name> = Custom) {
                    if ! GoalManager_GoalFlagSet Name=AU_Goal_Gaps19 flag=got_1 Skater=<Name> {
                        GoalManager_SetGoalFlag Name=AU_Goal_Gaps19 got_1 1 Skater=<Name> 
                    } 
                } else {
                    if (<Name> = ShrimpVendor) {
                        if ! GoalManager_GoalFlagSet Name=AU_Goal_Gaps19 flag=got_1 Skater=<Name> {
                            GoalManager_SetGoalFlag Name=AU_Goal_Gaps19 got_1 1 Skater=<Name> 
                        } 
                    } 
                } 
            } 
            if GoalManager_GoalFlagSet Name=AU_Goal_Gaps19 flag=got_1 Skater=Pro {
                <Awning_Grinds> = (<Awning_Grinds> + 1) 
            } 
            if GoalManager_GoalFlagSet Name=AU_Goal_Gaps19 flag=got_1 Skater=Custom {
                <Awning_Grinds> = (<Awning_Grinds> + 1) 
            } 
            if GoalManager_GoalFlagSet Name=AU_Goal_Gaps19 flag=got_1 Skater=ShrimpVendor {
                <Awning_Grinds> = (<Awning_Grinds> + 1) 
            } 
            if (<Awning_Grinds> = 0) {
                
                Printf "0" 
                
            } else {
                if (<Awning_Grinds> = 1) {
                    
                    Create_Panel_Message {text="1 of 3 Awning Grinds" Style=Goal_Collect_Text} 
                    
                } else {
                    if (<Awning_Grinds> = 2) {
                        
                        Create_Panel_Message {text="2 of 3 Awning Grinds" Style=Goal_Collect_Text} 
                        
                    } else {
                        break 
                        
                    } 
                } 
            } 
        } 
    } 
} 
script AU_Gap_KennyFingers_Start {
    StartGap GapID=FingerSpin Flags=[CANCEL_GROUND] 
    StartGap GapID=FingerKiss Flags=[CANCEL_GROUND] 
} 
script AU_Gap_KennyFingers_End {
    GetTriggerArray spin Onto 
    if Triggertype <trigger_array> {
        Printf "CR CR CR --- GOT SPIN ONTO!!!" 
        if ! GoalManager_GoalIsLocked Name=AU_Goal_Gaps21 {
            Printf "CR CR CR --- KENNY FINGER GOAL IS NOT LOCKED!!!" 
            EndGap GapID=FingerSpin Score=250 text="Peace Off!" 
            GoalManager_SetGoalFlag Name=AU_Goal_Gaps21 got_1 1 
            Wait 10 frames 
            if IsAlive Name=Geo_KennyFinger01 {
                ShatterAndDie Name=Geo_KennyFinger01 
            } 
        } 
    } else {
        Printf "CR CR CR --- GOT DUMPED OUT OF KENNY FINGER STUFF!" 
        EndGap GapID=FingerKiss Score=100 text="Peace Out!" 
    } 
} 
