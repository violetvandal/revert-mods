script AU_RuleSignBreak {
    GetTriggerArray Lip 
    if Triggertype <trigger_array> {
        if IsAlive Name=Geo_Sign_Rules01 {
            Wait 15 frames 
            GetBonus Score=1000 text="Destruction Bonus" 
            Shatter {Name=Geo_Sign_Rules01 
                area=2000 
                texture_swap=CG_AU_Shatter_BeachSign 
                variance=1.0 
                spread=1.5 
                life=6 
                bounce=0.5 
                scale=0.4 
                vel_x=0 
                vel_y=60 
                vel_z=0 
            } 
            Kill Name=Geo_Sign_Rules01 
        } 
    } 
} 
