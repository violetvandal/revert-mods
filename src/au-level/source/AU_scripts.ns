script AU_FootBridgeCheck {
    GetCurrentSkaterProfileIndex 
    GetSkaterProfileInfo Player=<CurrentSkaterProfileIndex> 
    Printf "CR CR CR --- Skater Name is %a" a=<Name> 
    if (<Name> = MiniKartDriver) {
        if ! GoalManager_HasWonGoal Name=AU_Goal_Gaps20 {
            Printf "CR CR CR --- 540 BRIDGE GOAL NOT WON!" 
            Skater:GetSpin 
            if (<spin> > 539) {
                Printf "CR CR CR --- GOAL FLAG IS NOT SET SO SET IT AND WIN!" 
                GoalManager_SetGoalFlag Name=AU_Goal_Gaps20 got_1 1 
            } 
        } 
    } 
} 
script AU_FlowerPot {
    GetBonus Score=1000 text="Destruction Bonus" 
    Shatter {Name=<Name> 
        area=2000 
        texture_swap=CG_AU_Shatter_Pot 
        variance=1.0 
        spread=1.5 
        life=6 
        bounce=0.5 
        scale=0.4 
        vel_x=0 
        vel_y=60 
        vel_z=0 
    } 
    Kill Name=<Name> 
    if ! IsAlive Name=<Plant> {
        Create Name=<Plant> 
        <Plant>:Rigidbody_Kick Vel=(0.0, 10.0, 0.0) 
    } 
    if GoalManager_GoalExists Name=AU_Classic_Goal_Collect {
        if ! GoalManager_HasWonGoal Name=AU_Classic_Goal_Collect {
            if (<Name> = AU_Classic_FlowerPot01) {
                
                Goal_Collect_Got_Object Goal_ID=AU_Classic_Goal_Collect flag=got_1 
                
            } else {
                if (<Name> = AU_Classic_FlowerPot02) {
                    
                    Goal_Collect_Got_Object Goal_ID=AU_Classic_Goal_Collect flag=got_2 
                    
                } else {
                    if (<Name> = AU_Classic_FlowerPot03) {
                        
                        Goal_Collect_Got_Object Goal_ID=AU_Classic_Goal_Collect flag=got_3 
                        
                    } else {
                        if (<Name> = AU_Classic_FlowerPot04) {
                            
                            Goal_Collect_Got_Object Goal_ID=AU_Classic_Goal_Collect flag=got_4 
                            
                        } else {
                            if (<Name> = AU_Classic_FlowerPot05) {
                                
                                Goal_Collect_Got_Object Goal_ID=AU_Classic_Goal_Collect flag=got_5 
                                
                            } 
                        } 
                    } 
                } 
            } 
        } 
    } 
} 
