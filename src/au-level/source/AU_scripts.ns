1 { TRG_SFX_Ghost_LifeguardYelling:Obj_PlayStream AU_LifeguardYell01 priority=StreamPriorityHigh vol=200 dropoff=600 ID=LifeguardStream 
 } 1 { TRG_SFX_Ghost_LifeguardYelling:Obj_PlayStream AU_LifeguardYell02 priority=StreamPriorityHigh vol=200 dropoff=600 ID=LifeguardStream 
