script AU_Ped_Busted_Running {
    Obj_ClearExceptions 
    Obj_LookAtNode Name=<Buddy> Speed=400 
    Wait random { 1 { 5 frames } 1 { 5 frames } 1 { 10 frames } 1 { 15 frames } 1 { 20 frames } } 
    Obj_CycleAnim Anim=Ped_M_Talk2_WhatDoYouThink 
    Wait random { 1 { 5 frames } 1 { 5 frames } 1 { 10 frames } 1 { 15 frames } 1 { 20 frames } } 
    Obj_LookAtNode Name=TRG_Waypoint_Busted Speed=400 
    Obj_WaitMove 
    Obj_PlayAnim Anim=RunFromIdle 
    Obj_MoveToNode Name=TRG_Waypoint_Busted Speed=12 
    Obj_WaitAnimFinished 
    Obj_CycleAnim Anim=Run 
    Obj_WaitMove 
    Die 
} 
