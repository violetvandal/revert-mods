script AU_Gap_BigStairs_Start {
    if Skater:IsSkaterFocused {
        StartGap GapID=BigStairs Flags=[PURE_AIR] TrickText="Double Heelflip" TrickScript=AU_DoubleHeel_Got 
    } else {
        StartGap GapID=BigStairs Flags=[PURE_AIR] 
    } 
} 
script AU_Gap_BigStairs_End {
    EndGap GapID=BigStairs Score=50 text="Big Stair Set" 
    Wait 30 frames 
    UnSetFlag flag=FLAG_360_GOT 
    UnSetFlag flag=FLAG_DOUBLEHEEL_GOT 
} 
script AU_DoubleHeel_Got {
    SetFlag flag=FLAG_DOUBLEHEEL_GOT 
} 
script AU_DoubleHeel_SpinCheck {
    if GoalManager_GoalExists Name=AU_Goal_Gaps14 {
        if ! GoalManager_GoalIsLocked Name=AU_Goal_Gaps14 {
            if ! GoalManager_HasWonGoal Name=AU_Goal_Gaps14 {
                Skater:GetSpin 
                if (<spin> = 360) {
                    SetFlag flag=FLAG_360_GOT 
                    SetException Ex=SkaterLandedClean Scr=AU_DoubleHeel_Clean Group=AU_DoubleHeel_Group 
                    Wait 30 frames 
                } 
            } 
        } 
    } 
    ClearExceptionGroup AU_DoubleHeel_Group 
} 
script AU_DoubleHeel_Clean {
    ClearExceptionGroup AU_DoubleHeel_Group 
    if GoalManager_GoalExists Name=AU_Goal_Gaps14 {
        if ! GoalManager_GoalIsLocked Name=AU_Goal_Gaps14 {
            if ! GoalManager_HasWonGoal Name=AU_Goal_Gaps14 {
                if GetFlag flag=FLAG_360_GOT {
                    Wait 15 frames 
                    if GetFlag flag=FLAG_DOUBLEHEEL_GOT {
                        GoalManager_SetGoalFlag Name=AU_Goal_Gaps14 got_1 1 
                    } 
                } 
            } 
        } 
    } 
} 
