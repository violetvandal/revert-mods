            GoalManager_SetGoalFlag Name=AU_Goal_Gaps11 got_1 1 
            Kill Prefix="TRG_Ped_ShrimpVendorChill" 
            Create Name=TRG_Ped_ShrimpVendor 
            Kill Name=TRG_Ped_CornGuy01 
            Create Name=TRG_Ped_CornGuy02 
        } 
    } 
} 
