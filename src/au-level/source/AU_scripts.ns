script AU_ShrimpSlap_Counter {
    Printstruct <...> 
    if GoalManager_GoalExists Name=AU_Goal_Gaps18 {
        Printf "CR CR CR CR --- SHRIMP SLAP GOAL EXISTS!" 
        ClearExceptionGroup Projectile 
        SetException Ex=PedHitByProjectile Scr=AU_ShrimpSlap_Check Group=Projectile Params={<...>} 
        Block 
    } 
} 
script AU_ShrimpSlap_Check {
    ClearExceptionGroup Projectile 
    Printstruct <...> 
    if ! GoalManager_HasWonGoal Name=AU_Goal_Gaps18 {
        if (Projectile_Last_Ped_ID = TRG_Ped_LifeGuard01) {
            GoalManager_SetGoalFlag Name=AU_Goal_Gaps18 got_1 1 
        } else {
            if (Projectile_Last_Ped_ID = TRG_Ped_LifeGuard02) {
                GoalManager_SetGoalFlag Name=AU_Goal_Gaps18 got_2 1 
            } else {
                if (Projectile_Last_Ped_ID = TRG_Ped_LifeGuard03) {
                    GoalManager_SetGoalFlag Name=AU_Goal_Gaps18 got_3 1 
                } else {
                    if (Projectile_Last_Ped_ID = TRG_Ped_LifeGuard04) {
                        GoalManager_SetGoalFlag Name=AU_Goal_Gaps18 got_4 1 
                    } else {
                        if (Projectile_Last_Ped_ID = TRG_Ped_LifeGuard05) {
                            GoalManager_SetGoalFlag Name=AU_Goal_Gaps18 got_5 1 
                        } 
                    } 
                } 
            } 
        } 
    } 
    GoToPreserveParams AU_ShrimpSlap_Counter 
} 
