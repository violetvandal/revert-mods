} 
script AU_GDAY_Got01 {
    if ! GoalManager_GoalFlagSet Name=AU_Classic_Goal_Gaps flag=got_1 {
        GoalManager_SetGoalFlag Name=AU_Classic_Goal_Gaps got_1 1 
        GoTo AU_Classic_GDAY_Message 
    } 
} 
