script AU_LampBulbBreak {
    PlaySound AU_PoppingStreetLight vol=200 pitch=random { 1 { 60 } 1 { 75 } 1 { 90 } } 
    PlaySound HitGlassPane2x vol=60 pitch=random { 1 { 120 } 1 { 130 } 1 { 140 } } 
    if IsAlive Name=<Bulb> {
        Printf "CR CR CR --- Bulb is alive...so shatter and kill" 
        GetUniqueCompositeObjectID preferredID=JOW_AU_LampSpark 
        CreateFastParticleSystem Name=<UniqueID> attachObjID=<Dummy> params_Script=JOW_AU_LampSparks01_fast_particle_params 
        Wait 10 frames 
        Kill Name=<Bulb> 
    } 
    if IsAlive Name=<NightBulb> {
        Printf "CR CR CR --- Night Bulb is alive...so shatter and kill" 
        GetUniqueCompositeObjectID preferredID=JOW_AU_LampSpark 
        CreateFastParticleSystem Name=<UniqueID> attachObjID=<Dummy> params_Script=JOW_AU_LampSparks01_fast_particle_params 
        Wait 10 frames 
        Kill Name=<NightBulb> 
    } 
    Create Name=<Spark> 
    if GoalManager_GoalIsActive Name=AU_Classic_Goal_Collect2 {
        if ! GoalManager_HasWonGoal Name=AU_Classic_Goal_Collect2 {
            if ! GoalManager_GoalFlagSet Name=AU_Classic_Goal_Collect2 flag=<flag> {
                Goal_Collect_Got_Object Goal_ID=AU_Classic_Goal_Collect2 flag=<flag> 
            } 
        } 
    } 
} 
