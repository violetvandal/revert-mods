                        Goal_Text=AU_Classic_HighCombo_Text 
                        View_Goals_Text=AU_Classic_HighCombo_Text 
                    } 
                ] 
                classic_mode_goal 
            } 
            AddGoal_Skate {
                unlimited_time 
                S_obj_id=TRG_SKATE_S 
                K_obj_id=TRG_SKATE_K 
                A_obj_id=TRG_SKATE_A 
                T_obj_id=TRG_SKATE_T 
                E_obj_id=TRG_SKATE_E 
                view_goals_cameras=[{virtual_cam 
                        targetid=world 
                        targetOffset=(-12354.8, -1004.1, 10510.0) 
                        positionOffset=(-2833.4, 650.3, 7939.6) 
                        frames=200 
                        skippable=1 
                    } 
                ] 
                classic_mode_goal 
            } 
            AddGoal_Combo {
                unlimited_time 
                letter_info=[
                    {obj_id=TRG_COMBO_C text="C"} 
                    {obj_id=TRG_COMBO_O text="O"} 
                    {obj_id=TRG_COMBO_M text="M"} 
                    {obj_id=TRG_COMBO_B text="B"} 
                    {obj_id=TRG_COMBO_O01 text="O"} 
                ] 
                view_goals_cameras=[{virtual_cam 
                        targetid=world 
                        targetOffset=(7275.5, -3435.2, 10185.1) 
                        positionOffset=(-1250.7, 544.2, 6798.9) 
                        frames=200 
                        skippable=1 
                    } 
                ] 
                classic_mode_goal} 
            AddGoal_collect {
                unlimited_time 
                collect_type="Flower Pots" 
                Goal_Text="Smash 5 Flower Pots" 
                View_Goals_Text="Smash 5 Flower Pots" 
                goal_description="Find and smash 5 Flower Pots" 
                use_hud_counter 
                hud_counter_caption="Pots Smashed" 
                goal_flags=[
                    got_1 
