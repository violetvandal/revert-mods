script ST_Setup {
    ST_vertcheck_init 
    ST_manualcheck_init 
    ST_wallcheck_init 
    ST_walkcheck_init 
    ST_combo_checkinit 
    ST_Initializer 
    ST_particles 
} 
script ST_startup {
    LoadAsset "models\\gameobjects\\projectiles\\SmokeBomb\\SmokeBomb.tex" 
    LoadAsset "models\\gameobjects\\projectiles\\SmokeBomb\\SmokeBomb.mdl" parent=`models\gameobjects\projectiles\SmokeBomb\SmokeBomb.tex` 
} 
