script ST_2d_sign_element_create {parent = menu3d_anchor 
    if GetGlobalFlag flag=SCREEN_MODE_WIDE {
        <offset> = (-8.0, 0.0) 
    } else {
        <offset> = (0.0, 0.0) 
    } 
    CreateScreenElement {
        type=ContainerElement 
        parent=<parent> 
        pos=(0.0, 0.0) 
        id=SK_bullet_holder 
        z_priority=-53 
    } 
    CreateScreenElement {
        type=SpriteElement 
        parent=SK_bullet_holder 
        texture=SK_icon_1 
        id=SK_bullet1 
        scale=1.5 
        rgba=[128 128 128 128] 
        pos=((9.0, 148.0) + <offset>) 
        rot_angle=0 
        just=[left top] 
    } 
    CreateScreenElement {
        type=SpriteElement 
        parent=SK_bullet_holder 
        texture=SK_icon_1 
        id=SK_bullet2 
        scale=1.5 
        rgba=[128 128 128 128] 
        pos=((9.0, 148.0) + <offset>) 
        rot_angle=0 
        just=[left top] 
    } 
    CreateScreenElement {
        type=SpriteElement 
        parent=SK_bullet_holder 
        texture=SK_icon_1 
        id=SK_bullet3 
        scale=1.5 
        rgba=[128 128 128 128] 
        pos=((9.0, 148.0) + <offset>) 
        rot_angle=0 
        just=[left top] 
    } 
    CreateScreenElement {
        type=SpriteElement 
        parent=SK_bullet_holder 
        texture=SK_icon_1 
        id=SK_bullet4 
        scale=1.5 
        rgba=[128 128 128 128] 
        pos=((9.0, 148.0) + <offset>) 
        rot_angle=0 
        just=[left top] 
    } 
    CreateScreenElement {
        type=SpriteElement 
        parent=SK_bullet_holder 
        texture=SK_icon_1 
        id=SK_bullet5 
        scale=1.5 
        rgba=[128 128 128 128] 
        pos=((9.0, 148.0) + <offset>) 
        rot_angle=0 
        just=[left top] 
    } 
    CreateScreenElement {
        type=SpriteElement 
        parent=<parent> 
        texture=SK_icon_2 
        id=SK_crash 
        scale=2.4 
        rgba=[128 128 128 128] 
        pos=((80.0, 370.0) + <offset>) 
        rot_angle=-20 
        just=[center center] 
        z_priority=-51 
    } 
    RunScriptOnScreenElement id=SK_bullet_holder SK_bullet_anim 
    RunScriptOnScreenElement id=SK_crash do_random_effect_paused params={id=<id>} 
} 
script SK_bullet_anim {
    while {
        bull1_pos = random { 1 { (-10.0, 30.0) } 1 { (-5.0, 90.0) } } 
        bull2_pos = random { 1 { (15.0, 150.0) } 1 { (60.0, 220.0) } } 
        bull3_pos = random { 1 { (90.0, 188.0) } 1 { (15.0, 220.0) } } 
        bull4_pos = random { 1 { (130.0, 240.0) } 1 { (24.0, 280.0) } } 
        bull5_pos = random { 1 { (120.0, 300.0) } 1 { (40.0, 320.0) } } 
        SK_bullet1:DoMorph time=0 pos=<bull1_pos> scale=1.8 alpha=0 
        SK_bullet2:DoMorph time=0 pos=<bull2_pos> scale=1.8 alpha=0 
        SK_bullet3:DoMorph time=0 pos=<bull3_pos> scale=1.8 alpha=0 
        SK_bullet4:DoMorph time=0 pos=<bull4_pos> scale=1.8 alpha=0 
        SK_bullet5:DoMorph time=0 pos=<bull5_pos> scale=1.8 alpha=0 
        DoMorph time=0 alpha=1 
        wait random { 1 { 1 } 1 { 2 } 1 { 3 } } seconds 
        SK_bullet1:DoMorph time=0.1 pos=<bull1_pos> alpha=1 
        wait random { 1 { 1 } 1 { 2 } 1 { 3 } } seconds 
        SK_bullet2:DoMorph time=0.1 pos=<bull2_pos> alpha=1 
        wait random { 1 { 1 } 1 { 2 } 1 { 3 } } seconds 
        SK_bullet3:DoMorph time=0.1 pos=<bull3_pos> alpha=1 
        wait random { 1 { 1 } 1 { 2 } 1 { 3 } } seconds 
        SK_bullet4:DoMorph time=0.1 pos=<bull4_pos> alpha=1 
        wait random { 1 { 1 } 1 { 2 } 1 { 3 } } seconds 
        SK_bullet5:DoMorph time=0.1 pos=<bull5_pos> alpha=1 
        wait random { 1 { 5 } 1 { 8 } 1 { 12 } } seconds 
        DoMorph time=1 alpha=0 
        wait random { 1 { 1 } 1 { 2 } 1 { 3 } } seconds 
    } 
} 
ST_CatLogic_Table = {
    ST_STATE_IdleCat={
        script_ped_state=ST_STATECONTROL_KittyNice 
    } 
    STATE_chasecatch={
        script_ped_state=ST_STATECONTROL_Kittycatch 
    } 
} 
script ST_STATECONTROL_KittyNice {
    OBJ_EnableAnimBlending enabled=1 
    Obj_SetInnerRadius 25 
    SetEventHandler EX=ObjectInRadius scr=ST_Cat_StartChase 
    while {
        random {
1 { PlayAnimWithPartialAnimIfExists anim=idle 
 } 1 { PlayAnimWithPartialAnimIfExists anim=SitFromIdle 
        Obj_waitAnimFinished 
        while {
            random {
1 { PlayAnimWithPartialAnimIfExists anim=SitIdle1 
 } 1 { PlayAnimWithPartialAnimIfExists anim=SitIdle2 
 } 1 { PlayAnimWithPartialAnimIfExists anim=SitIdle3 
 } } 
            Obj_waitAnimFinished 
        } 4 
        PlayAnimWithPartialAnimIfExists anim=SitFromIdle backwards 
 } } 
        if ! IsStreamPlaying CatMeowSFX {
            random {
4 { 
 } 1 { Obj_PlayStream ST_Cat_Idle01 vol=80 priority=StreamPriorityMidHigh dropoff=150 id=CatMeowSFX 
 } 1 { Obj_PlayStream ST_Cat_Idle02 vol=80 priority=StreamPriorityMidHigh dropoff=150 id=CatMeowSFX 
 } } 
        } 
        Obj_waitAnimFinished 
    } 
} 
script ST_Cat_StartChase {
    ClearEventHandler ObjectInRadius 
    Ped_Utils_BeginPlayerChase MaxHomeDist=25 Table=ST_CatLogic_Table 
} 
script ST_STATECONTROL_Kittycatch {
    PlayAnimWithPartialAnimIfExists anim=Pounce cycle 
    random {
1 { Obj_PlayStream ST_Cat_Angry01 vol=200 priority=StreamPriorityMidHigh dropoff=150 
 } 1 { Obj_PlayStream ST_Cat_Angry02 vol=200 priority=StreamPriorityMidHigh dropoff=150 
 } } 
    Obj_LockToObject (0.0, 59.0, 0.0) ObjectName=skater LagRange=(0.2, 0.4) 
    wait 0.3 seconds 
    if ! skater:walking {
        ShakeCamera {
            duration=2 
            vert_amp=4.0 
            horiz_amp=4.0 
            vert_vel=5.27 
            horiz_vel=10.92 
        } 
    } 
    PlayAnimWithPartialAnimIfExists anim=attack cycle 
    skater:Obj_GetScaling 
    sz = (((1 - (<scaling>.(0.0, 0.0, 1.0))) * -75) + 1) 
    catoffset = (<sz> * (0.0, 0.0, 1.0)) 
    Obj_LockToObject <catoffset> bone=bone_neck ObjectName=skater LagRange=(1.0, 1.0) 
    obj_getID 
    switch <objid>
        case TRG_ped_pinkcat {
            wait 2 seconds 
        }
        case TRG_ped_escape_pinkcat {
            wait 20 seconds 
        }
    endswitch    
    Obj_LockToObject off 
    PlayAnimWithPartialAnimIfExists anim=Pounce cycle 
    skater:Obj_GetPosition 
    <pos> = (<pos> + (60.0, 0.0, 60.0)) 
    Obj_MoveToPos <pos> time=0.15 
    Obj_WaitMove 
    Ped_GetCurrentNodeNames 
    Obj_MoveToNode name=<node_from> orient 
    PlayAnimWithPartialAnimIfExists anim=idle cycle 
    wait 5 seconds 
    Ped_StateLogic_SetDefaultState 
} 
