    block 
} 
script ST_invertair {
    
    setflag flag=FLAG_VERT 
    ClearExceptionGroup ST_vert 
    SetExceptionHandler EX=SkaterExitVertAir scr=ST_vertcheck Group=ST_vert 
    block 
} 
