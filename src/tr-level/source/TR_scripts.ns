script mod_skip_tutorial_exit {
    SetGlobalFlag flag=LEVEL_SEEN_TR 
    SetGlobalFlag flag=GOALS_EXPLAINED 
    SetGlobalFlag flag=TAP_BUTTONS_EXPLAINED 
    SetGlobalFlag flag=RECOVERY_BUTTONS_EXPLAINED 
    SetGlobalFlag flag=LEVEL_UNLOCKED_BO 
    SetGlobalFlag flag=LEVEL_SEEN_BO 
    Wait 2 seconds 
    level_select_change_level level=load_BO 
} 
