    Create name=TRG_Tony_Advance 
    TODManager_SetTempBloomParams on=0 
} 
script TR_ADDGOAL_Focus_Deactivate {
    ClearExceptionGroup TR_Goal_Gaps27 
    TODManager_SetTempBloomParams on=0 
} 
FLAG_FOCUS = 2 
