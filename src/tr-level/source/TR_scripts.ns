    ClearExceptionGroup TR_Goal_Gaps23 
    killspawnedScript name=TR_ADDGOAL_BackFlip_Checker 
} 
script TR_ADDGOAL_BackFlip_Deactivate {
    ClearExceptionGroup TR_Goal_Gaps23 
