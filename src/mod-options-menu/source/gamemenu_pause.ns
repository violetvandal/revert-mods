script toggle_mod_st_car {
    if ! GetGlobalFlag flag=MOD_ST_NO_CAR {
        SetScreenElementProps id={menu_mod_st_car child=3} text="Off" 
        SetGlobalFlag flag=MOD_ST_NO_CAR 
        if LevelIs Load_ST {
            ST_KillCars 
        } 
    } else {
        SetScreenElementProps id={menu_mod_st_car child=3} text="On" 
        UnsetGlobalFlag flag=MOD_ST_NO_CAR 
        if LevelIs Load_ST {
            pause_launch_level level=Load_ST 
        } 
    } 
} 
script toggle_mod_no_traffic {
    if ! GetGlobalFlag flag=MOD_NO_NO_TRAFFIC {
        SetScreenElementProps id={menu_mod_no_traffic child=3} text="Off" 
        SetGlobalFlag flag=MOD_NO_NO_TRAFFIC 
        if LevelIs Load_NO {
            NO_ApplyTrafficMod 
        } 
    } else {
        SetScreenElementProps id={menu_mod_no_traffic child=3} text="On" 
        UnsetGlobalFlag flag=MOD_NO_NO_TRAFFIC 
        if LevelIs Load_NO {
            pause_launch_level level=Load_NO 
        } 
    } 
} 
script toggle_mod_bo_traffic {
    if ! GetGlobalFlag flag=MOD_BO_NO_TRAFFIC {
        SetScreenElementProps id={menu_mod_bo_traffic child=3} text="Off" 
        SetGlobalFlag flag=MOD_BO_NO_TRAFFIC 
        if LevelIs Load_BO {
            BO_ApplyTrafficMod 
        } 
    } else {
        SetScreenElementProps id={menu_mod_bo_traffic child=3} text="On" 
        UnsetGlobalFlag flag=MOD_BO_NO_TRAFFIC 
        if LevelIs Load_BO {
            pause_launch_level level=Load_BO 
        } 
    } 
}
