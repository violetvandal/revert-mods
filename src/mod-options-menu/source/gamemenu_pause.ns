script mod_add_skipgoal_item {
    if GoalManager_GoalExists name=<goal> {
        GoalManager_GetGoalParams name=<goal> 
        if ! GotParam view_goals_text {
            view_goals_text = <goal> 
        } 
        sg_status = "Skip" 
        if GoalManager_HasWonGoal name=<goal> {
            sg_status = "Done" 
        } 
        theme_menu_add_item {text=<view_goals_text> extra_text=<sg_status> id=<goal> pad_choose_script=mod_skip_goal pad_choose_params={goal=<goal>}}
    }
}
script mod_add_skipgoal_bytype {
    GoalManager_CreateGoalName Goal_Type=<type>
    mod_add_skipgoal_item goal=<Goal_Id>
}
script mod_skip_goal {
    SpawnScript mod_skip_goal_deferred params={goal=<goal>} 
    exit_pause_menu 
} 
script mod_skip_goal_deferred {
    wait 5 frames 
    GoalManager_UnlockGoal name=<goal> 
    GoalManager_WinGoal name=<goal> 
} 
script skip_goal_back {
    if ScreenElementExists id=current_menu_anchor {
        DestroyScreenElement id=current_menu_anchor 
    } 
    create_level_mods_menu 
} 
script create_set_stats_menu {
    make_new_themed_sub_menu title="SET STATS" 
    create_helper_text {helper_text_elements=[{text="\\b7/\\b4 = Select"} 
            {text="\\bn = Back"} 
            {text="\\bm = +1"} 
        ] 
    } 
    SetScreenElementProps {id=sub_menu 
        event_handlers=[
            {pad_back generic_menu_pad_back params={callback=set_stats_back}} 
        ] 
    } 
    mod_add_stat_item name=air text="Air" id=menu_ss_air 
    mod_add_stat_item name=speed text="Speed" id=menu_ss_speed 
    mod_add_stat_item name=ollie text="Ollie" id=menu_ss_ollie 
    mod_add_stat_item name=spin text="Spin" id=menu_ss_spin 
    mod_add_stat_item name=`switch` text="Switch" id=menu_ss_switch 
    mod_add_stat_item name=flip_speed text="Flip Speed" id=menu_ss_flip 
    mod_add_stat_item name=rail_balance text="Rail" id=menu_ss_rail 
    mod_add_stat_item name=lip_balance text="Lip" id=menu_ss_lip 
    mod_add_stat_item name=manual_balance text="Manual" id=menu_ss_manual 
    mod_add_stat_item name=run text="Run" id=menu_ss_run 
    mod_max_stats_item id=menu_ss_max 
    theme_menu_add_item text="Done" id=menu_ss_done pad_choose_script=set_stats_back last_menu_item=1 
    finish_themed_sub_menu 
} 
script mod_add_stat_item {
    GetStatValue <name> 
    if (<stat_value> > 10) {
        stat_value = 10 
    } 
    FormatText textname=valstr "%i" i=<stat_value> 
    theme_menu_add_item {text=<text> 
        extra_text=<valstr> 
        id=<id> 
        pad_choose_script=mod_cycle_stat 
        pad_choose_params={name=<name> id=<id>} 
    } 
} 
script mod_cycle_stat {
    GetStatValue <name> 
    new_val = (<stat_value> + 1) 
    if (<new_val> > 10) {
        new_val = 0 
    } 
    stat_menu_change_stat name=<name> value=<new_val> 
    UpdateSkaterStats player=0 
    FormatText textname=valstr "%i" i=<new_val> 
    SetScreenElementProps id={<id> child=3} text=<valstr> 
} 
script set_stats_back {
    if ScreenElementExists id=current_menu_anchor {
        DestroyScreenElement id=current_menu_anchor 
    } 
    create_level_mods_menu 
} 
script level_mods_exit {
    if ScreenElementExists id=current_menu_anchor {
        DestroyScreenElement id=current_menu_anchor 
    } 
    create_pause_menu 
} 
script toggle_mod_au_gulls {
    if ! GetGlobalFlag flag=MOD_AU_SILENCE_GULLS {
        SetScreenElementProps id={menu_mod_au_gulls child=3} text="On" 
        SetGlobalFlag flag=MOD_AU_SILENCE_GULLS 
    } else {
        SetScreenElementProps id={menu_mod_au_gulls child=3} text="Off" 
        UnsetGlobalFlag flag=MOD_AU_SILENCE_GULLS 
    } 
} 
