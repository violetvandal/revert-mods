    } 
} 
script NO_Crypt4_open {
    Obj_MoveToRelPos (0.0, -2.0, 0.0) speed=1 
    Obj_WaitMove 
    while {
        Obj_MoveToRelPos (0.0, 2.0, 0.0) speed=1 
        Obj_WaitMove 
        Obj_MoveToRelPos (0.0, -2.0, 0.0) speed=1 
        Obj_WaitMove 
    } 
} 
script NO_Crypt5_open {
    Obj_RotY speed=30 angle=2 flag_max_coords 
