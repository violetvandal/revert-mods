                Create name=TRG_Ped_Hint_Skulls 
            } 
        } 
        if ! GoalManager_GoalIsLocked name=NO_Goal_SkateTheLine2 {
            if ! GoalManager_HasWonGoal name=NO_Goal_SkateTheLine2 {
                Create name=TRG_Ped_Hint_Spine 
            } 
        } 
        if GoalManager_HasWonGoal name=NO_Goal_Gaps2 {
            if ! isAlive name=TRG_Switchable_Jester {
                Create name=TRG_Switchable_Jester 
            } 
        } 
        if ! isAlive name=TRG_veh_heli {
            if GoalManager_HasWonGoal name=NO_Goal_Gaps6 {
                if ! isAlive name=TRG_ped_voodoo_tricycle01 {
