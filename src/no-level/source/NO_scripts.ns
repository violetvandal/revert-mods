        if GoalManager_HasWonGoal name=NO_Goal_Gaps8 {
            Create prefix="SPAT_COVER" 
        } else {
            Create prefix="SPAT" 
            kill prefix="SPAT_COVER" 
        } 
        if ! GoalManager_GoalIsLocked name=NO_Goal_Gaps5 {
            if ! GoalManager_HasWonGoal name=NO_Goal_Gaps5 {
                Create name=TRG_Ped_Hint_Birds 
            } 
        } 
        if ! GoalManager_GoalIsLocked name=NO_Goal_Gaps6 {
