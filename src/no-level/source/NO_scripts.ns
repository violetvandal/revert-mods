script NO_GotVortexSpine {
    GoalManager_SetGoalFlag name=NO_Goal_SkateTheLine got_1 1 
    if GoalManager_HasWonGoal name=NO_Goal_SkateTheLine {
        if ! GetFlag flag=FLAG_JESUS {
            SetFlag flag=FLAG_JESUS 
        } 
    } 
} 
