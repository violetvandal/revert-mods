script NO_2d_sign_element_create {parent = menu3d_anchor 
    if GetGlobalFlag flag=SCREEN_MODE_WIDE {
        <offset> = (-8.0, 0.0) 
    } else {
        <offset> = (0.0, 0.0) 
    } 
    CreateScreenElement {
        Type=SpriteElement 
        parent=<parent> 
        texture=NO_icon_1 
        id=NO_lemon 
        scale=1.5 
        rgba=[128 128 128 50] 
        pos=((9.0, 148.0) + <offset>) 
        rot_angle=0 
        just=[left top] 
        z_priority=-51 
    } 
    CreateScreenElement {
        Type=SpriteElement 
        parent=<parent> 
        texture=NO_icon_2 
        id=NO_bubbles 
        scale=(1.5, 1.5) 
        rgba=[128 128 128 60] 
        pos=((16.0, 184.0) + <offset>) 
        rot_angle=0 
        just=[center center] 
        z_priority=-51 
    } 
    RunScriptOnScreenElement id=NO_lemon do_random_effect_paused params={id=<id>} 
    RunScriptOnScreenElement id=NO_bubbles NO_bubbles_anim 
} 
script NO_bubbles_anim {
    while {
        DoMorph time=0 pos=(53.0, 300.0) scale=1.2 rot_angle=-90 alpha=1 
        DoMorph time=1 pos=(53.0, 275.0) rot_angle=-98 alpha=0.5 
        DoMorph time=2 pos=(53.0, 230.0) rot_angle=-80 alpha=0 
        wait random { 1 { 2 } 1 { 3 } 1 { 4 } } seconds 
    } 
} 
NO_MardisGras_F_Table = {
    NO_STATE_F_MardisGras_Dance={
        script_ped_state=NO_STATECONTROL_F_MardisGras_Dance 
        exit_state_action=wait_anim_finished 
    } 
    STATE_GetAttention={
        script_ped_state=NO_STATECONTROL_F_MardisGras_GetAttention 
        exit_state_action=wait_anim_finished 
    } 
    STATE_shot={
        high_priority 
        script_ped_state=NO_STATECONTROL_F_MardisGras_ShowEm 
        exit_state_action=NO_STATE_ShowEm_Reset 
    } 
    STATE_avoidstop={
        high_priority 
        script_ped_state=STATECONTROL_avoidstop_custom01 
        exit_state_action=wait_anim_finished 
    } 
    STATE_avoidland={
        script_ped_state=STATECONTROL_avoidland_custom01 
    } 
} 
script NO_Musicplay {
    trg_ped_jazz_00:Ped_SetLogicState NO_STATE_Jazzman_playing Table=NO_StateLogic_Table 
    trg_ped_jazz_02:Ped_SetLogicState NO_STATE_fluteguy_playing Table=NO_StateLogic_Table 
    trg_ped_jazz_01:Ped_SetLogicState ALL_STATE_guitarist_playing Table=ALL_StateLogic_Table 
    UnPauseSkaters 
} 
script NO_MusicStop {
    trg_ped_jazz_00:Ped_SetLogicState NO_STATE_Jazzman Table=NO_StateLogic_Table 
    trg_ped_jazz_02:Ped_SetLogicState NO_STATE_fluteguy Table=NO_StateLogic_Table 
    trg_ped_jazz_01:Ped_SetLogicState ALL_STATE_guitarist Table=ALL_StateLogic_Table 
    UnPauseSkaters 
} 
script NO_STATECONTROL_F_MardisGras_Dance {
    obj_getid 
    <objid>:SwitchOffAtomic ped_f_accessories 
    while {
        random {
3 { PlayAnimWithPartialAnimIfExists anim=Ped_F_Dance1 speed=0.75 
 } 1 { PlayAnimWithPartialAnimIfExists anim=Ped_F_Dance2 speed=0.75 
 } 1 { PlayAnimWithPartialAnimIfExists anim=Ped_F_Dance3 speed=0.9 
 } } 
        Obj_WaitAnimFinished 
    } 
} 
script NO_STATECONTROL_F_MardisGras_GetAttention {
    ped_rotate_to_skater_from_idle 
    while {
        if ! Obj_ObjectInAttentionRadius {
            break 
        } 
        PlayAnimWithPartialAnimIfExists anim=Ped_F_Dance_GetAttention speed=0.9 
        Obj_WaitAnimFinished 
    } 1 
    Ped_Utils_SetMiscEventHandlers 
    Ped_StateLogic_SetDefaultState 
} 
script NO_STATECONTROL_F_MardisGras_ShowEm {
    ped_initialize_projectile_exceptions 
    ped_standing_look_at_skater 
    if ! IsStreamPlaying GirlShowStream {
        random2 {
1 { Obj_PlayStream NO_Female1_Flash01 vol=200 dropoff=150 priority=StreamPriorityLowMid id=GirlShowStream 
 } 1 { Obj_PlayStream NO_Female1_Flash02 vol=200 dropoff=150 priority=StreamPriorityLowMid id=GirlShowStream 
 } 1 { Obj_PlayStream NO_Female1_Flash03 vol=200 dropoff=150 priority=StreamPriorityLowMid id=GirlShowStream 
 } 1 { Obj_PlayStream NO_Female1_Flash04 vol=200 dropoff=150 priority=StreamPriorityLowMid id=GirlShowStream 
 } 1 { Obj_PlayStream NO_Female1_Flash05 vol=200 dropoff=150 priority=StreamPriorityLowMid id=GirlShowStream 
 } 1 { Obj_PlayStream NO_Female1_Flash06 vol=200 dropoff=150 priority=StreamPriorityLowMid id=GirlShowStream 
 } 1 { Obj_PlayStream NO_Female1_Flash07 vol=200 dropoff=150 priority=StreamPriorityLowMid id=GirlShowStream 
 } 1 { Obj_PlayStream NO_Female1_Flash08 vol=200 dropoff=150 priority=StreamPriorityLowMid id=GirlShowStream 
 } 1 { Obj_PlayStream NO_Female1_Flash09 vol=200 dropoff=150 priority=StreamPriorityLowMid id=GirlShowStream 
 } 1 { Obj_PlayStream NO_Female1_Flash10 vol=200 dropoff=150 priority=StreamPriorityLowMid id=GirlShowStream 
 } } 
    } 
    PlayAnimWithPartialAnimIfExists anim=Ped_F_ShowEm 
    wait 40 frames 
    obj_getid 
    <objid>:SwitchOnAtomic ped_f_accessories 
    wait 64 frames 
    <objid>:SwitchOffAtomic ped_f_accessories 
    Obj_WaitAnimFinished 
    Ped_Utils_SetMiscEventHandlers 
    ped_initialize_collision_exceptions 
    Ped_StateLogic_SetDefaultState 
} 
script NO_STATE_ShowEm_Reset {
    obj_getid 
