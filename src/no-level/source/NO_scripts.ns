script NO_ApplyTrafficMod {
    if GetGlobalFlag flag=MOD_NO_NO_TRAFFIC {
        Kill name=TRG_streetcar 
        Kill name=TRG_veh_float1 
        Kill name=TRG_veh_float2 
        Kill name=TRG_veh_jester1 
        Kill name=TRG_veh_jester2 
        Kill name=TRG_veh_donkey1 
